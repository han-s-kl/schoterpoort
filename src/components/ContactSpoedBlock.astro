---
import practiceData from '../data/practices.json';

interface Props {
  lang?: string;
}

const { lang = 'nl' } = Astro.props;
const isEn = lang === 'en';
const ot = practiceData.openingstijden;
const spoedItem = practiceData.keuzemenu.find((item: any) => /spoed/i.test(item.label));
const spoedKey = spoedItem?.key || '1';
---

<div class="mt-10 space-y-6">
  <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
    <h2 class="text-lg font-bold text-neutral-900 mb-3">Contact</h2>
    <p class="text-sm text-neutral-700 font-semibold">Schoterpoort huisartsenpraktijken</p>
    <p class="text-sm text-neutral-600">{practiceData.address}</p>
    <p class="text-sm text-neutral-600 mt-2">
      {isEn ? 'Telephone' : 'Telefoon'}: <a href={`tel:${practiceData.phoneGeneral.replace(/\s/g, '')}`} class="text-dark-600 no-underline hover:underline">{practiceData.phoneGeneral}</a>
    </p>
    <p class="text-sm text-neutral-600">
      E-mail: <a href={`mailto:${practiceData.email}`} class="text-dark-600 no-underline hover:underline">{practiceData.email}</a>
    </p>
    <div class="mt-3 text-sm text-neutral-600">
      <p class="font-medium mb-1">{isEn ? 'Menu options' : 'Keuzemenu'}:</p>
      <ul class="list-disc list-inside space-y-0.5">
        {practiceData.keuzemenu.map((item: any) => (
          <li>{isEn ? `Option ${item.key}` : `Keuze ${item.key}`}: {item.label}</li>
        ))}
      </ul>
    </div>
  </div>

  <div class="bg-accent-50 border-l-4 border-accent-400 rounded-r-lg p-5">
    <h2 class="text-lg font-bold text-accent-800 mb-2">{isEn ? 'Emergencies' : 'Spoed'}</h2>
    <ul class="text-sm text-accent-700 space-y-1">
      <li>{isEn
        ? `During office hours: your GP's number followed by ${spoedKey}`
        : `Tijdens kantooruren: nummer van uw huisarts gevolgd door ${spoedKey}`}</li>
      <li>{isEn ? `After ${ot.close} and at weekends` : `Na ${ot.close} en in het weekend`}: <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="font-semibold underline">{isEn ? 'Emergency Post' : 'Spoedpost'} {practiceData.phoneEmergency}</a></li>
      <li>{isEn ? 'In emergencies' : 'In noodgevallen'}: <a href="tel:112" class="font-semibold underline">112</a></li>
    </ul>
  </div>
</div>
