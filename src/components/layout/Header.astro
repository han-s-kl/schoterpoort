---
import navigationNl from '../../data/navigation.json';
import navigationEn from '../../data/navigation-en.json';
import practiceData from '../../data/practices.json';
import { url } from '../../utils/url';

interface Props {
  lang?: 'nl' | 'en';
}

const { lang = 'nl' } = Astro.props;
const navigation = lang === 'en' ? navigationEn : navigationNl;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

// Language switch URL: swap /en/ prefix
const switchUrl = lang === 'en'
  ? url(currentPath.replace(/\/en(\/|$)/, '/').replace(base, '') || '/')
  : url(`/en${currentPath.replace(base, '') || '/'}`);
---

<header>
  <!-- Logo banner -->
  <div class="bg-[#c2ac57]">
    <a href={url('/')} class="block no-underline max-w-7xl mx-auto">
      <img
        src={`${base}/images/logo.png`}
        alt="Huisartsenpraktijk Schoterpoort -- M.M. Duijn, L. van der Eem, M. Louwet, W.H. Steketee"
        class="block h-20 sm:h-28 lg:h-32 w-auto"
      />
    </a>
  </div>

  <!-- Contact bar -->
  <div class="bg-dark-800 text-white text-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-1.5 sm:py-2 flex justify-between items-center gap-2">
      <span class="text-white hidden sm:inline">Pijnboomstraat 19, 2023 VN Haarlem</span>
      <div class="flex items-center gap-3 sm:gap-4">
        <a href={`tel:${practiceData.phoneGeneral.replace(/[\s-]/g, '')}`} class="text-white font-medium hover:text-primary-300 no-underline flex items-center gap-1.5 text-xs sm:text-sm">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {practiceData.phoneGeneral}
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Navigation (sticky - outside header so sticky works) -->
<nav class="bg-white border-b border-neutral-200 shadow-sm sticky top-0 z-50" aria-label="Hoofdnavigatie">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-11 lg:h-12">
        <!-- Desktop menu -->
        <ul class="hidden lg:flex items-center gap-1" role="menubar">
          {navigation.map((item) => (
            <li class="relative group" role="none">
              <a
                href={url(item.href)}
                role="menuitem"
                class:list={[
                  'px-3 py-2 rounded-lg text-sm font-medium no-underline transition-colors',
                  currentPath === item.href || (item.href !== '/' && item.href !== '#' && currentPath.startsWith(item.href))
                    ? 'text-dark-700 bg-primary-50'
                    : 'text-neutral-700 hover:text-dark-700 hover:bg-neutral-50',
                ]}
                aria-current={currentPath === item.href ? 'page' : undefined}
                aria-haspopup={item.children ? 'true' : undefined}
              >
                {item.label}
                {item.children && (
                  <svg class="w-3.5 h-3.5 inline ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                )}
              </a>
              {item.children && (
                <ul class="absolute left-0 top-full pt-1 hidden group-hover:block" role="menu">
                  <li class="bg-white rounded-lg shadow-lg border border-neutral-200 py-1 min-w-56">
                    {item.children.map((child) => (
                      <a
                        href={url(child.href)}
                        role="menuitem"
                        class:list={[
                          'block px-4 py-2 text-sm no-underline transition-colors',
                          currentPath === child.href
                            ? 'text-dark-700 bg-primary-50'
                            : 'text-neutral-700 hover:text-dark-700 hover:bg-neutral-50',
                        ]}
                      >
                        {child.label}
                      </a>
                    ))}
                  </li>
                </ul>
              )}
            </li>
          ))}
        </ul>

        <!-- Language switch (desktop) -->
        <a
          href={switchUrl}
          class="hidden lg:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium no-underline border border-neutral-200 hover:bg-neutral-50 transition-colors"
        >
          <span class:list={[lang === 'nl' ? 'font-bold text-neutral-900' : 'text-neutral-400 opacity-60']}>
            <svg class="inline w-4 h-3 mr-0.5" viewBox="0 0 640 480"><rect width="640" height="160" fill="#AE1C28"/><rect y="160" width="640" height="160" fill="#FFF"/><rect y="320" width="640" height="160" fill="#21468B"/></svg>NL
          </span>
          <span class="text-neutral-300">|</span>
          <span class:list={[lang === 'en' ? 'font-bold text-neutral-900' : 'text-neutral-400 opacity-60']}>
            <svg class="inline w-4 h-3 mr-0.5" viewBox="0 0 640 480"><rect width="640" height="480" fill="#012169"/><path d="M75 0l244 181L562 0h78v62L400 241l240 178v61h-80L320 301 81 480H0v-60l239-178L0 64V0h75z" fill="#FFF"/><path d="M424 281l216 159v40L369 281h55zm-184 20l6 35L54 480H0l240-179zM640 0v3L391 191l2-44L590 0h50zM0 0l239 176h-60L0 42V0z" fill="#C8102E"/><path d="M241 0v480h160V0H241zM0 160v160h640V160H0z" fill="#FFF"/><path d="M273 0v480h96V0h-96zM0 192v96h640v-96H0z" fill="#C8102E"/></svg>EN
          </span>
        </a>

        <!-- Mobile: small logo + hamburger -->
        <a href={url(lang === 'en' ? '/en' : '/')} class="lg:hidden flex items-center no-underline">
          <span class="text-sm font-bold text-neutral-900">Schoterpoort</span>
        </a>

        <!-- Mobile menu button -->
        <button
          type="button"
          id="mobile-menu-toggle"
          class="lg:hidden p-2 -mr-2 rounded-lg text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Menu openen"
        >
          <svg class="w-6 h-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu (outside flex container) -->
    <div id="mobile-menu" class="lg:hidden hidden border-t border-neutral-100 bg-white max-h-[70vh] overflow-y-auto" role="menu">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <ul class="space-y-1">
          {navigation.map((item) => (
            <li>
              <a
                href={url(item.href)}
                class:list={[
                  'block px-3 py-2.5 rounded-lg text-sm font-medium no-underline',
                  currentPath === item.href
                    ? 'text-dark-700 bg-primary-50'
                    : 'text-neutral-700 hover:bg-neutral-50',
                ]}
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="ml-4 mt-1 space-y-0.5">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={url(child.href)}
                        class:list={[
                          'block px-3 py-2 rounded-lg text-sm no-underline',
                          currentPath === child.href
                            ? 'text-dark-700 bg-primary-50'
                            : 'text-neutral-500 hover:text-neutral-700 hover:bg-neutral-50',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
        <div class="mt-3 pt-3 border-t border-neutral-200 px-3 flex justify-between items-center">
          <div class="flex gap-4">
            <a href={`tel:${practiceData.phoneGeneral.replace(/[\s-]/g, '')}`} class="text-dark-600 font-medium text-sm no-underline">{practiceData.phoneGeneral}</a>
            <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="text-accent-600 font-semibold text-sm no-underline">Spoed: {practiceData.phoneEmergency}</a>
          </div>
          <a href={switchUrl} class="flex items-center gap-1.5 px-2 py-1 rounded text-xs font-medium no-underline border border-neutral-200">
            {lang === 'nl' ? (
              <Fragment><svg class="inline w-4 h-3 mr-0.5" viewBox="0 0 640 480"><rect width="640" height="480" fill="#012169"/><path d="M75 0l244 181L562 0h78v62L400 241l240 178v61h-80L320 301 81 480H0v-60l239-178L0 64V0h75z" fill="#FFF"/><path d="M424 281l216 159v40L369 281h55zm-184 20l6 35L54 480H0l240-179zM640 0v3L391 191l2-44L590 0h50zM0 0l239 176h-60L0 42V0z" fill="#C8102E"/><path d="M241 0v480h160V0H241zM0 160v160h640V160H0z" fill="#FFF"/><path d="M273 0v480h96V0h-96zM0 192v96h640v-96H0z" fill="#C8102E"/></svg> EN</Fragment>
            ) : (
              <Fragment><svg class="inline w-4 h-3 mr-0.5" viewBox="0 0 640 480"><rect width="640" height="160" fill="#AE1C28"/><rect y="160" width="640" height="160" fill="#FFF"/><rect y="320" width="640" height="160" fill="#21468B"/></svg> NL</Fragment>
            )}
          </a>
        </div>
      </div>
    </div>
  </nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    toggle.setAttribute('aria-label', expanded ? 'Menu openen' : 'Menu sluiten');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
