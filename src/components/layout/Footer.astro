---
import practiceData from '../../data/practices.json';
import { url } from '../../utils/url';

interface Props {
  lang?: 'nl' | 'en';
}

const { lang = 'nl' } = Astro.props;
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const prefix = lang === 'en' ? '/en' : '';
---

<footer class="bg-dark-900 text-dark-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Contact -->
      <div>
        <h2 class="text-white font-semibold text-lg mb-4">Contact</h2>
        <address class="not-italic space-y-2 text-sm">
          <p set:html={practiceData.address.replace(',', '<br />')} />
          <p>
            <a href={`tel:${practiceData.phoneGeneral.replace(/[\s-]/g, '')}`} class="text-white hover:text-primary-300 no-underline">{practiceData.phoneGeneral}</a>
          </p>
          <p>
            <a href={`mailto:${practiceData.email}`} class="text-dark-300 hover:text-white no-underline">{practiceData.email}</a>
          </p>
          <p class="pt-2">
            <strong class="text-white">Openingstijden:</strong><br />
            {practiceData.openingstijden.daysShort} {practiceData.openingstijden.open} -- {practiceData.openingstijden.close}
          </p>
          <p class="pt-2">
            <strong class="text-accent-400">Spoed buiten kantooruren:</strong><br />
            <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="text-white hover:text-accent-300 no-underline font-semibold">{practiceData.phoneEmergency}</a>
            <br /><span class="text-xs text-dark-400">Spoedpost Haarlem</span>
          </p>
        </address>
      </div>

      <!-- Links -->
      <div>
        <h2 class="text-white font-semibold text-lg mb-4">Snel naar</h2>
        <ul class="space-y-2 text-sm">
          <li><a href={url('/telefoonnummers')} class="text-dark-300 hover:text-white no-underline transition-colors">Telefoonnummers</a></li>
          <li><a href={url('/spreekuur-afspraken')} class="text-dark-300 hover:text-white no-underline transition-colors">Spreekuur & afspraken</a></li>
          <li><a href={url('/spoedpost')} class="text-dark-300 hover:text-white no-underline transition-colors">Spoedpost</a></li>
          <li><a href={url('/tarieven-2025')} class="text-dark-300 hover:text-white no-underline transition-colors">Tarieven 2025</a></li>
          <li><a href={url('/medewerkers/huisartsen')} class="text-dark-300 hover:text-white no-underline transition-colors">Onze huisartsen</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h2 class="text-white font-semibold text-lg mb-4">Gezondheidsinfo</h2>
        <ul class="space-y-2 text-sm">
          <li><a href="https://www.thuisarts.nl/" target="_blank" rel="noopener" class="text-dark-300 hover:text-white no-underline transition-colors">Thuisarts.nl</a></li>
          <li><a href="https://www.moetiknaardedokter.nl/" target="_blank" rel="noopener" class="text-dark-300 hover:text-white no-underline transition-colors">Moet ik naar de dokter?</a></li>
          <li><a href="https://www.rijksoverheid.nl/onderwerpen/verkeersveiligheid/vraag-en-antwoord/medicijnen-in-het-verkeer/" target="_blank" rel="noopener" class="text-dark-300 hover:text-white no-underline transition-colors">Medicijnen en verkeer</a></li>
          <li><a href="https://www.pharos.nl/" target="_blank" rel="noopener" class="text-dark-300 hover:text-white no-underline transition-colors">Pharos.nl</a></li>
          <li><a href={url('/gezondheid')} class="text-dark-300 hover:text-white no-underline transition-colors">Alle gezondheidsinfo</a></li>
        </ul>
        <div class="mt-6 pt-4 border-t border-dark-700 text-xs text-dark-400 space-y-1">
          <p><a href={`${base}/documents/Jaarverslag-2023-Huisartsenpraktijk-Schoterpoort.pdf`} class="hover:text-dark-200 no-underline">Jaarverslag 2023</a></p>
          <p><a href={`${base}/documents/Jaarverslag-2022-Huisartsenpraktijk-Schoterpoort.pdf`} class="hover:text-dark-200 no-underline">Jaarverslag 2022</a></p>
          <p><a href={`${base}/documents/Beleidsplan-2025-2027-Huisartsenpraktijk-Schoterpoort.pdf`} class="hover:text-dark-200 no-underline">Beleidsplan 2025-2027</a></p>
        </div>
        <div class="mt-4 pt-4 border-t border-dark-700 text-xs text-dark-400 space-y-1">
          <p><a href={url('/privacy')} class="hover:text-dark-200 no-underline">Privacyverklaring</a></p>
          <p><a href={url('/medisch-dossier')} class="hover:text-dark-200 no-underline">Medisch dossier</a></p>
          <p><a href={url('/klachtenregeling')} class="hover:text-dark-200 no-underline">Klachtenregeling</a></p>
          <p><a href={url('/cookiewetgeving')} class="hover:text-dark-200 no-underline">Cookiewetgeving</a></p>
          <p><a href={url('/minderjarigen-wilsonbekwamen')} class="hover:text-dark-200 no-underline">Minderjarigen en wilsonbekwamen</a></p>
          <p>NPA gecertificeerd sinds 2006</p>
          <p>Onderwijspraktijk UvA/Amsterdam UMC</p>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-dark-700 text-center text-xs text-dark-500">
      <p>&copy; {currentYear} Huisartsenpraktijk Schoterpoort, Haarlem</p>
    </div>
  </div>
</footer>
