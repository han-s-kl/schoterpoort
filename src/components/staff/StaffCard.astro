---
interface Props {
  name: string;
  role: string;
  team?: string;
  photo?: string;
  workingDays?: string[];
  since?: string;
  background?: string;
  specializations?: string[];
  interests?: string;
  phone?: string;
  bigNumber?: string;
}

const { name, role, photo, team, workingDays, since, background, specializations, interests, phone, bigNumber } = Astro.props;
const base = import.meta.env.BASE_URL;
const photoUrl = photo ? `${base}${photo}` : undefined;

const initials = name
  .split(' ')
  .filter((part) => part[0] === part[0].toUpperCase())
  .map((part) => part[0])
  .slice(0, 2)
  .join('');
---

<div class="bg-white rounded-xl border border-neutral-200 p-5 hover:shadow-sm transition-shadow">
  <div class="flex items-start gap-4">
    <!-- Photo or initials -->
    {photoUrl ? (
      <img
        src={photoUrl}
        alt={`Foto van ${name}`}
        class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-primary-100"
        loading="lazy"
      />
    ) : (
      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-dark-100 to-dark-200 flex items-center justify-center shrink-0">
        <span class="text-dark-600 font-bold text-lg">{initials}</span>
      </div>
    )}

    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-neutral-900 text-lg">{name}</h3>
      <p class="text-sm text-dark-600 font-medium">{role}</p>

      {phone && (
        <a href={`tel:${phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-1 text-sm text-dark-500 no-underline hover:text-dark-700 mt-1">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {phone}
        </a>
      )}

      {workingDays && workingDays.length > 0 && (
        <p class="text-xs text-neutral-500 mt-2">
          <span class="font-medium">Werkdagen:</span> {workingDays.join(', ')}
        </p>
      )}

      {since && (
        <p class="text-xs text-neutral-400 mt-1">Werkzaam sinds {since}</p>
      )}

      {background && (
        <p class="text-sm text-neutral-600 mt-3 leading-relaxed">{background}</p>
      )}

      {specializations && specializations.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-2">
          {specializations.map((spec) => (
            <span class="text-xs bg-primary-50 text-primary-700 px-2 py-0.5 rounded-full">{spec}</span>
          ))}
        </div>
      )}

      {interests && (
        <p class="text-xs text-neutral-400 mt-2 italic">Interesses: {interests}</p>
      )}

      {bigNumber && (
        <p class="text-xs text-neutral-300 mt-1">BIG: {bigNumber}</p>
      )}
    </div>
  </div>
</div>
