---
import '../styles/global.css';
import practiceData from '../data/practices.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: 'nl' | 'en';
}

const {
  title,
  description = 'Huisartsenpraktijk Schoterpoort in Haarlem - vier huisartsen, persoonlijke zorg.',
  ogImage = '/images/og-default.jpg',
  lang = 'nl',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'Home' ? 'Huisartsenpraktijk Schoterpoort' : `${title} | Huisartsenpraktijk Schoterpoort`;
const ogLocale = lang === 'en' ? 'en_US' : 'nl_NL';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "name": "Huisartsenpraktijk Schoterpoort",
      "description": "Huisartsenpraktijk met vier huisartsen in Haarlem. NPA gecertificeerd, onderwijspraktijk UvA/Amsterdam UMC.",
      "url": "https://schoterpoort.com",
      "telephone": "+31235410345",
      "email": "info@schoterpoort.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Pijnboomstraat 19",
        "addressLocality": "Haarlem",
        "postalCode": "2023 VN",
        "addressCountry": "NL"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": practiceData.openingstijden.open,
        "closes": practiceData.openingstijden.close
      },
      "medicalSpecialty": "PrimaryCare",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "8.5",
        "bestRating": "10",
        "worstRating": "1"
      }
    })} />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-primary-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
    >
      Ga naar inhoud
    </a>

    <slot name="header" />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <script is:inline>
      // Open external links and PDF links in a new tab.
      // Runs once per page load, after the DOM is parsed.
      (function () {
        var host = window.location.hostname;
        var links = document.querySelectorAll('a[href]');
        for (var i = 0; i < links.length; i++) {
          var a = links[i];
          var href = a.getAttribute('href');
          if (!href) continue;

          // Skip anchors and non-navigational protocols
          if (href.charAt(0) === '#') continue;
          if (/^(tel:|mailto:|javascript:)/i.test(href)) continue;

          var isExternal = false;
          var isPdf = false;

          if (/^https?:\/\//i.test(href)) {
            try {
              var u = new URL(href);
              if (u.hostname !== host) isExternal = true;
            } catch (e) {}
          }

          var pathOnly = href.split('?')[0].split('#')[0];
          if (/\.pdf$/i.test(pathOnly)) isPdf = true;

          if (isExternal || isPdf) {
            a.setAttribute('target', '_blank');
            var rel = a.getAttribute('rel') || '';
            if (rel.indexOf('noopener') === -1) {
              a.setAttribute('rel', (rel ? rel + ' ' : '') + 'noopener');
            }
          }
        }
      })();
    </script>
  </body>
</html>
