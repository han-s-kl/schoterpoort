---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Pagina niet gevonden">
  <section class="py-20 lg:py-32">
    <div class="max-w-lg mx-auto px-4 text-center">
      <p class="text-6xl font-bold text-primary-200 mb-4">404</p>
      <h1 class="text-2xl font-bold text-neutral-900 mb-3">Pagina niet gevonden</h1>
      <p class="text-neutral-600 mb-8">
        De pagina die u zoekt bestaat niet of is verplaatst.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-dark-700 text-white font-semibold px-6 py-3 rounded-xl no-underline hover:bg-dark-800 transition-colors"
      >
        Terug naar home
      </a>
    </div>
  </section>
</PageLayout>
