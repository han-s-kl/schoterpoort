---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const healthPageIds = [
    'reizigersadvisering', 'soa', 'spiraal', 'tekenbeet',
    'wrattenspreekuur', 'urineweginfecties', 'zwangerschap',
  ];
  const pages = await getCollection('pages');
  return pages
    .filter((p) => healthPageIds.includes(p.id))
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<PageLayout title={page.data.title} description={page.data.description}>
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm">
        <a href="/gezondheid" class="text-dark-600 hover:text-dark-700 no-underline">&larr; Gezondheidsinfo</a>
      </nav>
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </article>
    </div>
  </section>
</PageLayout>
