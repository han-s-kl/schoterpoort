---
import PageLayout from '../layouts/PageLayout.astro';
import patData from '../data/patientenomgeving.json';
import { url } from '../utils/url';

const base = import.meta.env.BASE_URL;
---

<PageLayout title={patData.pageTitle || 'Patiëntenomgeving'} description={patData.pageDescription || 'Toegang tot uw online patiëntenportaal bij Huisartsenpraktijk Schoterpoort.'}>
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-6">{patData.pageTitle || 'Patiëntenomgeving'}</h1>

      <p class="text-neutral-600 mb-8" set:html={patData.intro} />

      <!-- Portal buttons -->
      <h2 class="text-xl font-bold mb-4">Inloggen op uw portaal</h2>
      <div class="grid sm:grid-cols-2 gap-3 mb-10">
        {patData.portals.map((portal) => (
          <a
            href={portal.href}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-between bg-white rounded-xl p-4 border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all no-underline group"
          >
            <span class="font-semibold text-neutral-900 group-hover:text-dark-700 text-sm">{portal.name}</span>
            <svg class="w-5 h-5 text-neutral-400 group-hover:text-dark-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        ))}
      </div>

      <!-- Belangrijk -->
      <h2 class="text-xl font-bold mb-4">Belangrijk</h2>
      <div class="space-y-3 mb-10">
        {patData.belangrijk.map((item) => {
          const colors = item.type === 'info'
            ? { bg: 'bg-blue-50', border: 'border-blue-400', text: 'text-blue-800' }
            : { bg: 'bg-amber-50', border: 'border-amber-400', text: 'text-amber-800' };
          return (
            <div class={`${colors.bg} border-l-4 ${colors.border} rounded-r-lg p-4`}>
              <p class={`text-sm ${colors.text}`} set:html={item.text} />
            </div>
          );
        })}
      </div>

      <!-- App -->
      <div class="flex items-center gap-5 bg-neutral-50 rounded-xl p-5 border border-neutral-200 mb-6">
        <a href={patData.appUrl} target="_blank" rel="noopener">
          <img
            src={`${base}/images/uwzorgonline-app.png`}
            alt="UwZorgOnline app"
            class="w-16 h-16 rounded-xl"
          />
        </a>
        <div>
          <h3 class="font-bold text-neutral-900 text-sm">Mobiele app</h3>
          <p class="text-sm text-neutral-600 mt-0.5">De patiëntenomgeving is ook beschikbaar als app.</p>
          <a href={patData.appUrl} target="_blank" rel="noopener" class="text-xs text-dark-600 font-medium no-underline hover:underline mt-1 inline-block">
            Bekijk de installatiehandleiding &rarr;
          </a>
        </div>
      </div>

      <!-- Helpdesk -->
      <div class="bg-white rounded-xl p-5 border border-neutral-200">
        <h2 class="font-bold text-neutral-900 mb-2">Hulp nodig?</h2>
        <p class="text-sm text-neutral-600 mb-3">
          Problemen met inloggen of uw account aanmaken? Neem contact op met de Helpdesk Digitale Zorg:
        </p>
        <div class="flex flex-wrap gap-4 text-sm">
          <a href={`tel:${patData.helpTelefoon.replace(/\s/g, '')}`} class="inline-flex items-center gap-1.5 text-dark-600 font-medium no-underline hover:text-dark-700">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {patData.helpTelefoon}
          </a>
          <a href={patData.helpWebsite} target="_blank" rel="noopener" class="text-dark-600 font-medium no-underline hover:text-dark-700">
            helpdeskdigitalezorg.nl &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
