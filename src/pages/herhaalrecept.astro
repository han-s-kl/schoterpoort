---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import practiceData from '../data/practices.json';

const pages = await getCollection('pages');
const page = pages.find((p) => p.id === 'herhaalrecept');
const { Content } = await render(page!);

const recept = practiceData.keuzemenu.find((item: any) => /recept/i.test(item.label));
const receptKey = recept?.key || '2';
---

<PageLayout title={page!.data.title} description={page!.data.description}>
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />

        <h2>2. Via de receptenlijn (telefoon)</h2>
        <p>Bel het praktijk-telefoonnummer van uw eigen huisarts en kies voor <strong>keuzetoets {receptKey}</strong>.</p>
        <ul>
          {practiceData.practices.map((practice: any) => (
            <li>{practice.name}: <a href={`tel:${practice.phone.replace(/[\s-]/g, '')}`}>{practice.phone}</a></li>
          ))}
        </ul>

        <p>Op de receptenlijn worden automatisch de volgende vragen aan u gesteld:</p>
        <ul>
          <li>De naam van uw huisarts</li>
          <li>Naam en geboortedatum van degene waarvoor het recept bedoeld is</li>
          <li>Straat en huisnummer woonadres</li>
          <li>Naam of namen van de medicijnen die u bestelt (houd de doosjes bij de hand!)</li>
          <li>Naam van uw eigen apotheek</li>
        </ul>

        <h2>Welke medicijnen kunt u aanvragen?</h2>
        <p>U kunt alleen recepten aanvragen voor medicijnen die u op advies van uw huisarts of specialist <strong>chronisch</strong> (meestal dagelijks) gebruikt.</p>
        <p>Wilt u medicijnen voor nieuw opgetreden klachten aanvragen of tijdelijke medicijnen -- die u voor een bepaalde periode hebt gekregen -- opnieuw aanvragen, dan kunt u deze geneesmiddelen <strong>niet</strong> via de receptenlijn of website bestellen. Hiervoor kunt u overdag met de praktijkassistente bellen, zo nodig wordt met uw huisarts overlegd over de aanvraag.</p>

        <h2>Wanneer liggen uw medicijnen klaar?</h2>
        <p>Indien u de receptenlijn inspreekt of een recept bestelt via de website <strong>voor 12:00 uur 's middags</strong>, dan kunt u <strong>2 werkdagen later</strong> uw medicijnen afhalen bij uw eigen apotheek (vanaf 15:00 liggen zij gereed).</p>
        <p>Voorbeelden:</p>
        <ul>
          <li>Belt/mailt u dinsdagavond, dan liggen uw medicijnen <strong>vrijdag</strong> bij de apotheek klaar.</li>
          <li>Belt/mailt u vrijdagmiddag na 12:00 uur of in het weekend, dan kunt u uw medicijnen <strong>woensdag na 15:00 uur</strong> afhalen.</li>
        </ul>
      </article>
    </div>
  </section>
</PageLayout>
