---
import PageLayout from '../../layouts/PageLayout.astro';
import StaffCard from '../../components/staff/StaffCard.astro';
import allStaff from '../../data/staff.json';
import { getEntry, render } from 'astro:content';
import { url } from '../../utils/url';

const nurses = allStaff.filter((s) => s.role === 'Praktijkverpleegkundige somatiek');
const supportNurse = allStaff.filter((s) => s.role === 'Spreekuurondersteuner');
const pohGgz = allStaff.filter((s) => s.role === 'Praktijkondersteuner GGZ');
const practiceManager = allStaff.filter((s) => s.role === 'Praktijkmanager');

const somatiekEntry = await getEntry('pages', 'praktijkondersteuners-somatiek');
const sprondEntry = await getEntry('pages', 'praktijkondersteuners-spreekuurondersteuner');
const ggzEntry = await getEntry('pages', 'praktijkondersteuners-ggz');
const { Content: SomatiekContent } = await render(somatiekEntry!);
const { Content: SprondContent } = await render(sprondEntry!);
const { Content: GgzContent } = await render(ggzEntry!);
---

<PageLayout
  title="Praktijkondersteuners"
  description="Informatie over de praktijkondersteuners somatiek, spreekuurondersteuner en POH-GGZ"
>
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm">
        <a href={url('/medewerkers')} class="text-dark-600 hover:text-dark-700 no-underline">&larr; Medewerkers</a>
      </nav>

      <h1 class="text-3xl lg:text-4xl font-bold mb-8">Praktijkondersteuners</h1>

      <!-- Praktijkverpleegkundigen somatiek -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Praktijkverpleegkundigen somatiek</h2>
        <SomatiekContent />
      </article>

      {nurses.length > 0 && (
        <div class="grid gap-4 mb-12">
          {nurses.map((member) => (
            <StaffCard
              name={member.name}
              role={member.role}
              team={member.team}
              photo={(member as any).photo}
              workingDays={member.workingDays}
              since={(member as any).since}
              background={(member as any).background}
              specializations={(member as any).specializations}
              interests={(member as any).interests}
              bigNumber={(member as any).bigNumber}
            />
          ))}
        </div>
      )}

      <!-- Spreekuurondersteuner -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Spreekuurondersteuner</h2>
        <SprondContent />
      </article>

      {supportNurse.length > 0 && (
        <div class="grid gap-4 mb-12">
          {supportNurse.map((member) => (
            <StaffCard
              name={member.name}
              role={member.role}
              photo={(member as any).photo}
              workingDays={member.workingDays}
              since={(member as any).since}
              background={(member as any).background}
              specializations={(member as any).specializations}
              interests={(member as any).interests}
              bigNumber={(member as any).bigNumber}
            />
          ))}
        </div>
      )}

      <!-- Praktijkondersteuners GGZ -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Praktijkondersteuners GGZ</h2>
        <GgzContent />
      </article>

      {pohGgz.length > 0 && (
        <div class="grid gap-4 mb-12">
          {pohGgz.map((member) => (
            <StaffCard
              name={member.name}
              role={member.role}
              team={member.team}
              photo={(member as any).photo}
              workingDays={member.workingDays}
              since={(member as any).since}
              background={(member as any).background}
              specializations={(member as any).specializations}
              interests={(member as any).interests}
              bigNumber={(member as any).bigNumber}
            />
          ))}
        </div>
      )}

      {practiceManager.length > 0 && (
        <>
          <h2 class="text-2xl font-bold mb-4">Praktijkmanager</h2>
          <div class="grid gap-4">
            {practiceManager.map((member) => (
              <StaffCard
                name={member.name}
                role={member.role}
                team={member.team}
                photo={(member as any).photo}
                workingDays={member.workingDays}
                since={(member as any).since}
                background={(member as any).background}
                specializations={(member as any).specializations}
                interests={(member as any).interests}
                bigNumber={(member as any).bigNumber}
              />
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</PageLayout>
