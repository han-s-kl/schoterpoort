---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const allNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="Nieuws" description="Laatste nieuws van Huisartsenpraktijk Schoterpoort.">
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-10">Nieuws</h1>
      {allNews.length === 0 ? (
        <p class="text-neutral-500">Er zijn momenteel geen nieuwsberichten.</p>
      ) : (
        <div class="grid gap-4">
          {allNews.map((article) => (
            <a
              href={url(`/nieuws/${article.id}`)}
              class="block bg-white rounded-xl border border-neutral-200 p-6 hover:border-primary-300 hover:shadow-md transition-all no-underline group"
            >
              <time class="text-sm text-neutral-400">
                {article.data.date.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h2 class="text-lg font-bold text-neutral-900 group-hover:text-dark-600 mt-1">{article.data.title}</h2>
              <p class="text-neutral-600 text-sm mt-1">{article.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>
