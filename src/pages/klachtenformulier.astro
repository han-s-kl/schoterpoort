---
import PageLayout from '../layouts/PageLayout.astro';
import practiceData from '../data/practices.json';
import { url } from '../utils/url';
---

<PageLayout title="Klachtenformulier" description="Dien een klacht in bij Huisartsenpraktijk Schoterpoort via een beveiligd ZIVVER-bericht.">
  <section class="py-12 lg:py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">Klacht indienen</h1>

      <p class="text-neutral-600 mb-8">
        Heeft u een klacht? Via ZIVVER kunt u een beveiligd bericht sturen
        aan de klachtenfunctionaris van de praktijk. U ontvangt een bevestiging
        van ontvangst en er wordt contact met u opgenomen over de vervolgstappen.
      </p>

      <div class="bg-primary-50 rounded-xl border-2 border-primary-200 p-8 text-center">
        <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-5">
          <svg class="w-7 h-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-neutral-900 mb-2">Beveiligd klacht indienen via ZIVVER</h2>
        <p class="text-sm text-neutral-600 mb-6">Uw klacht wordt beveiligd verzonden naar de klachtenfunctionaris.</p>

        <div class="space-y-3 mb-6 text-left">
          <div class="bg-accent-50 border-l-4 border-accent-400 rounded-r-lg p-4">
            <p class="text-sm text-accent-800 font-semibold">Dit formulier is niet bedoeld voor medische spoedvragen. Bij spoed belt u direct uw huisarts of buiten kantooruren de Spoedpost (<a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="underline">{practiceData.phoneEmergency}</a>).</p>
          </div>
        </div>

        <a
          href="https://app.zivver.com/l/start/de82dba5-f8cf-4001-b23b-6378c09368f0"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-dark-700 text-white font-semibold px-8 py-3 rounded-xl no-underline hover:bg-dark-800 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          Klacht indienen via ZIVVER
        </a>

        <div class="mt-8 pt-6 border-t border-primary-200 text-left text-sm text-neutral-600">
          <h3 class="font-semibold text-neutral-700 mb-2 text-center">Lukt het niet via ZIVVER?</h3>
          <p class="text-xs text-neutral-500 mb-3 text-center">Bel de praktijk tijdens kantooruren ({practiceData.openingstijden.daysShort} {practiceData.openingstijden.open} -- {practiceData.openingstijden.close}):</p>
          <ul class="space-y-1">
            {practiceData.practices.map((practice) => (
              <li class="flex items-center justify-between">
                <span class="text-xs">{practice.name}</span>
                <a href={`tel:${practice.phone.replace(/\s/g, '')}`} class="text-dark-700 font-medium no-underline text-xs">{practice.phone}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="text-xs text-neutral-400 mt-6">
        Meer informatie over onze klachtenprocedure vindt u op de <a href={url('/klachtenregeling')} class="underline">klachtenregeling</a> pagina.
      </p>
    </div>
  </section>
</PageLayout>
