---
import PageLayout from '../layouts/PageLayout.astro';
import { url } from '../utils/url';
---

<PageLayout title="Klachtenformulier" description="Dien een klacht in bij Huisartsenpraktijk Schoterpoort.">
  <section class="py-12 lg:py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">Klachtenformulier</h1>

      <p class="text-neutral-600 mb-8">
        Heeft u een klacht? Hiervoor kunt u gebruik maken van het klachtenformulier.
        Vul hieronder uw klacht in en u krijgt zo spoedig mogelijk bericht van ons.
      </p>

      <!-- TODO: verwijder deze melding zodra PHP-backend actief is op TransIP -->
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
        <p class="text-sm text-amber-800"><strong>Let op:</strong> Dit formulier opent uw e-mailprogramma. Het formulier wordt volledig online werkend zodra de site op de definitieve hosting staat.</p>
      </div>

      <form
        action={`mailto:info@schoterpoort.com?subject=Klacht via website`}
        method="POST"
        enctype="text/plain"
        class="space-y-5"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="voornaam" class="block text-sm font-medium text-neutral-700 mb-1">Voornaam</label>
            <input
              type="text"
              id="voornaam"
              name="Voornaam"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
          <div>
            <label for="achternaam" class="block text-sm font-medium text-neutral-700 mb-1">Achternaam <span class="text-accent-500">*</span></label>
            <input
              type="text"
              id="achternaam"
              name="Achternaam"
              required
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
        </div>

        <div>
          <label for="adres" class="block text-sm font-medium text-neutral-700 mb-1">Adres</label>
          <input
            type="text"
            id="adres"
            name="Adres"
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="postcode" class="block text-sm font-medium text-neutral-700 mb-1">Postcode</label>
            <input
              type="text"
              id="postcode"
              name="Postcode"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
          <div>
            <label for="plaats" class="block text-sm font-medium text-neutral-700 mb-1">Plaats</label>
            <input
              type="text"
              id="plaats"
              name="Plaats"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
        </div>

        <div>
          <label for="telefoon" class="block text-sm font-medium text-neutral-700 mb-1">Telefoon <span class="text-accent-500">*</span></label>
          <input
            type="tel"
            id="telefoon"
            name="Telefoon"
            required
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">E-mailadres <span class="text-accent-500">*</span></label>
          <input
            type="email"
            id="email"
            name="E-mailadres"
            required
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div>
          <label for="klacht" class="block text-sm font-medium text-neutral-700 mb-1">Uw klacht <span class="text-accent-500">*</span></label>
          <textarea
            id="klacht"
            name="Uw klacht"
            required
            rows="6"
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none resize-y"
          ></textarea>
        </div>

        <div class="flex items-center justify-between pt-2">
          <p class="text-xs text-neutral-400"><span class="text-accent-500">*</span> Verplicht veld</p>
          <button
            type="submit"
            class="bg-dark-700 text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-dark-800 transition-colors text-sm"
          >
            Versturen
          </button>
        </div>
      </form>

      <p class="text-xs text-neutral-400 mt-6">
        Meer informatie over onze klachtenprocedure vindt u op de <a href={url('/klachtenregeling')} class="underline">klachtenregeling</a> pagina.
      </p>
    </div>
  </section>
</PageLayout>
