---
import PageLayout from '../layouts/PageLayout.astro';
import PracticeCard from '../components/PracticeCard.astro';
import practiceData from '../data/practices.json';
import homeData from '../data/home.json';
import { getCollection, render } from 'astro:content';
import { url } from '../utils/url';

const allBlocks = (await getCollection('blocks'))
  .filter((b) => b.data.visible);

const practices = practiceData.practices;
---

<PageLayout title={homeData.pageTitle || 'Home'} description={homeData.pageDescription}>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-800 via-dark-700 to-dark-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,175,97,0.3),transparent_60%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="max-w-2xl">
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white">
          Huisartsenpraktijk<br />
          <span class="text-primary-400">Schoterpoort</span>
        </h1>
        <p class="mt-6 text-lg text-dark-200 leading-relaxed">
          Vier praktijken, acht huisartsen, persoonlijke zorg. Wij zijn een
          NPA-gecertificeerde groepspraktijk in Haarlem met een
          patiënttevredenheidsscore van 8,5 tot 9.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={url('/contact')}
            class="inline-flex items-center gap-2 bg-white/10 text-white font-semibold px-6 py-3 rounded-xl no-underline hover:bg-white/20 transition-colors border border-white/20"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick actions -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4">
        {[
          { label: 'Spreekuur', href: '/spreekuur-afspraken', icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5' },
          { label: 'Herhaalrecept', href: '/herhaalrecept', icon: 'M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859' },
          { label: 'Patiëntenomgeving', href: '/patientenomgeving', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
          { label: 'Telefoonnummers', href: '/telefoonnummers', icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z' },
          { label: 'Spoedpost', href: '/spoedpost', icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z' },
        ].map((action) => (
          <a
            href={url(action.href)}
            class="flex flex-col items-center gap-2 bg-white rounded-xl p-4 md:p-5 shadow-md hover:shadow-lg transition-shadow no-underline text-center border border-neutral-100"
          >
            <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={action.icon} />
              </svg>
            </div>
            <span class="text-sm font-medium text-neutral-700">{action.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Actuele mededelingen -->
  {allBlocks.length > 0 && (
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold mb-6">Actuele mededelingen</h2>
        <div class="space-y-4">
          {allBlocks.map(async (block) => {
            const { Content } = await render(block);
            const styles = {
              warning: { bg: 'bg-amber-50', border: 'border-amber-400', icon: 'text-amber-500', title: 'text-amber-900', text: 'text-amber-800', iconPath: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z' },
              info: { bg: 'bg-blue-50', border: 'border-blue-400', icon: 'text-blue-500', title: 'text-blue-900', text: 'text-blue-800', iconPath: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5' },
              neutral: { bg: 'bg-neutral-50', border: 'border-neutral-300', icon: 'text-neutral-400', title: 'text-neutral-800', text: 'text-neutral-600', iconPath: 'M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z' },
            };
            const s = styles[block.data.type];
            return (
              <div class={`${s.bg} border-l-4 ${s.border} rounded-r-lg p-5`}>
                <div class="flex gap-3">
                  <svg class={`w-5 h-5 ${s.icon} shrink-0 mt-0.5`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={s.iconPath} />
                  </svg>
                  <div>
                    <h3 class={`font-semibold ${s.title} text-sm`}>{block.data.title}</h3>
                    <div class={`text-sm ${s.text} mt-1 prose prose-sm max-w-none`}>
                      <Content />
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Practices -->
  <section class="py-16 lg:py-24 bg-neutral-50" id="praktijken">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold">Onze praktijken</h2>
        <p class="mt-3 text-neutral-600 max-w-2xl mx-auto" set:html={homeData.praktijkenIntro} />
      </div>

      <div class="grid sm:grid-cols-2 gap-4 lg:gap-6">
        {practices.map((practice) => (
          <PracticeCard practice={practice} />
        ))}
      </div>

      <div class="mt-8 text-center space-y-1">
        <p class="text-sm text-neutral-500">
          <strong>Algemeen nummer:</strong> <a href={`tel:${practiceData.phoneGeneral.replace(/[\s-]/g, '')}`} class="no-underline hover:underline">{practiceData.phoneGeneral}</a> &nbsp;|&nbsp;
          <strong>Open:</strong> {practiceData.openingstijden.daysShort} {practiceData.openingstijden.open} - {practiceData.openingstijden.close}{practiceData.avondspreekuur.enabled && ' (avondspreekuur op afspraak)'}
        </p>
        <p class="text-sm text-neutral-500">
          <strong>Adres:</strong> {practiceData.address}
        </p>
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="py-10 bg-accent-50 border-y border-accent-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
        <div class="w-14 h-14 rounded-full bg-accent-100 flex items-center justify-center shrink-0">
          <svg class="w-7 h-7 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <div class="text-center md:text-left">
          <h2 class="text-xl font-bold text-neutral-900 mb-1">Spoed buiten openingstijden?</h2>
          <p class="text-neutral-600 text-sm mb-3">
            Bel de Spoedpost Haarlem voor avond-, nacht- en weekendzorg. Bij levensbedreigende situaties: bel 112.
          </p>
          <a
            href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`}
            class="inline-flex items-center gap-2 bg-accent-600 text-white font-semibold px-5 py-2.5 rounded-lg no-underline hover:bg-accent-700 transition-colors"
          >
            Bel {practiceData.phoneEmergency}
          </a>
          <div>
            <a href={url('/spoedpost')} class="inline-block mt-3 text-xs text-accent-700 hover:text-accent-800 underline">
              Meer info over de Spoedpost
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Afspraak afzeggen -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto">
        <!-- Afspraak afzeggen -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-900 mb-1">Afspraak afzeggen</h3>
              <p class="text-sm text-neutral-600" set:html={homeData.afspraakAfzeggen} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Health resources -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">Gezondheidsinfo</h2>
      <div class="space-y-4">
        <a
          href="https://www.thuisarts.nl/"
          target="_blank"
          rel="noopener"
          class="group block bg-white rounded-xl p-6 border border-neutral-200 hover:border-primary-300 hover:shadow-md transition-all no-underline"
        >
          <h3 class="font-bold text-neutral-900 group-hover:text-dark-600 mb-2">Thuisarts.nl</h3>
          <p class="text-sm text-neutral-600">Betrouwbare gezondheidsinformatie van huisartsen.</p>
        </a>
        <div class="bg-white rounded-xl p-6 border border-neutral-200">
          <h3 class="font-bold text-neutral-900 mb-2">Moet ik naar de dokter?</h3>
          <p class="text-sm text-neutral-600 mb-4">Zelftriage: doorloop de vragen en ontvang direct advies.</p>
          <div id="mindd_widget_embedded"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team photo -->
  {homeData.teamPhoto && (
    <section class="py-8 bg-neutral-50">
      <div class="max-w-5xl mx-auto px-4">
        <img src={`${import.meta.env.BASE_URL}${homeData.teamPhoto}`} alt="Het team van Huisartsenpraktijk Schoterpoort" class="w-full rounded-xl shadow-sm" />
      </div>
    </section>
  )}

  <!-- Kwaliteit & Team -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Kwaliteit</h2>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex flex-col md:flex-row gap-6">
          {homeData.kwaliteit.filter(k => k.visible !== false).slice(0, 2).map((item, i) => (
            <div class={`flex-1 rounded-xl p-6 border ${i === 0 ? 'bg-primary-50 border-primary-100' : 'bg-neutral-50 border-neutral-200'}`}>
              {item.title && <h3 class="font-bold text-neutral-900 mb-2">{item.title}</h3>}
              <p class="text-sm text-neutral-700" set:html={item.text} />
            </div>
          ))}
        </div>
        {homeData.kwaliteit.filter(k => k.visible !== false).slice(2).map((item) => (
          <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
            {item.title && <h3 class="font-bold text-neutral-900 mb-2">{item.title}</h3>}
            <p class="text-sm text-neutral-700" set:html={item.text} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wist u dat? -->
  <section class="py-16 lg:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Wist u dat?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {(() => {
          const icons = [
            'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z',
            'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
            'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
            'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
            'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
            'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
            'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
            'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
          ];
          return homeData.wistUDat.map((text, i) => (
            <div class="bg-white rounded-xl p-5 border border-neutral-200 shadow-sm">
              <div class="w-8 h-8 rounded-full bg-primary-50 flex items-center justify-center mb-3">
                <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icons[i] || icons[0]} />
                </svg>
              </div>
              <p class="text-sm text-neutral-700" set:html={text} />
            </div>
          ));
        })()}
      </div>
    </div>
  </section>

  <script is:inline src="https://moetiknaardedokter.azurewebsites.net/embed/index.js" type="text/javascript"></script>
  <script is:inline define:vars={{ phoneGeneral: practiceData.phoneGeneral }}>
    window.addEventListener('DOMContentLoaded', function() {
      if (window.mindd) {
        window.mindd.init({
          ApiKey: '4krC1VIVe4CHBIvRoW9hpStBZZE8Ys4M',
          target: '#mindd_widget_embedded',
          type: 'widget',
          accent_color: '#265e61',
          welcome_text: {
            NL: '**Moet u naar de dokter?** \n\n Doorloop de vragen en ontvang direct advies.',
            EN: '**Should you see a doctor?** \n\n Answer the questions and receive immediate advice.'
          },
          open: false,
          modalDisplayMode: 'full',
          widget_showWelcomeText: true,
          showLanguageSelector: true,
          defaultLanguageCode: 'NL',
          getSessionSummaryUsingForm: false,
          startQuestionType: 'gender',
          startWithAbcdTriage: false,
          labels: {
            QuestionWhatGender: {
              NL: "Bent u een man of een vrouw?",
              EN: "Are you (the patiënt) a man or a woman?"
            },
            QuestionWhatSearchTriage: {
              NL: "Waar heeft u last van?",
              EN: "What is bothering you?"
            }
          },
          branding: {
            termsOfUseUrl: "https://www.moetiknaardedokter.nl/gebruikersvoorwaarden/",
            name: "Huisartsenpraktijk Schoterpoort",
            phone_label: "Algemeen nummer",
            phone_number: phoneGeneral,
            font_family: "Raleway"
          },
          sessionTimeOutInSec: 0,
          clickOutsideModalClosesModal: false
        });
      }
    });
  </script>


</PageLayout>
