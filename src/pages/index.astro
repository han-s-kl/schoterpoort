---
import PageLayout from '../layouts/PageLayout.astro';
import practiceData from '../data/practices.json';
import { getCollection } from 'astro:content';

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const practices = practiceData.practices;
---

<PageLayout title="Home">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-800 via-dark-700 to-dark-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,175,97,0.3),transparent_60%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="max-w-2xl">
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white">
          Huisartsenpraktijk<br />
          <span class="text-primary-400">Schoterpoort</span>
        </h1>
        <p class="mt-6 text-lg text-dark-200 leading-relaxed">
          Vier huisartsen, persoonlijke zorg. Wij zijn een NPA-gecertificeerde
          groepspraktijk in Haarlem met een patiënttevredenheidsscore van 8,5 tot 9.
        </p>
        <p class="mt-3 text-sm text-dark-300">
          <em>Welcome to Huisartsenpraktijk Schoterpoort. For information in English, please visit our <a href="/information" class="text-primary-300 underline hover:text-primary-200">English information page</a>.</em>
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/telefoonnummers"
            class="inline-flex items-center gap-2 bg-primary-400 text-dark-900 font-semibold px-6 py-3 rounded-xl no-underline hover:bg-primary-300 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Bel ons
          </a>
          <a
            href="/spreekuur"
            class="inline-flex items-center gap-2 bg-white/10 text-white font-semibold px-6 py-3 rounded-xl no-underline hover:bg-white/20 transition-colors border border-white/20"
          >
            Afspraak maken
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick actions -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4">
        {[
          { label: 'Spreekuur', href: '/spreekuur', icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5' },
          { label: 'Herhaalrecept', href: '/herhaalrecept', icon: 'M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859' },
          { label: 'Patientenomgeving', href: '/patientenomgeving', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
          { label: 'Telefoonnummers', href: '/telefoonnummers', icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z' },
          { label: 'Spoedpost', href: '/spoedpost', icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z' },
        ].map((action) => (
          <a
            href={action.href}
            class="flex flex-col items-center gap-2 bg-white rounded-xl p-4 md:p-5 shadow-md hover:shadow-lg transition-shadow no-underline text-center border border-neutral-100"
          >
            <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={action.icon} />
              </svg>
            </div>
            <span class="text-sm font-medium text-neutral-700">{action.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Actuele mededelingen -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold mb-6">Actuele mededelingen</h2>
      <div class="space-y-4">
        <!-- Personeelstekort -->
        <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
              <h3 class="font-semibold text-amber-900 text-sm">Personeelstekort door ziekte</h3>
              <p class="text-sm text-amber-800 mt-1">
                Wegens ziekte hebben we een beperkt assistententeam. Kijk eerst op
                <a href="https://www.moetiknaardedokter.nl/" target="_blank" rel="noopener" class="font-medium underline">moetiknaardedokter.nl</a> of
                <a href="https://www.thuisarts.nl/" target="_blank" rel="noopener" class="font-medium underline">thuisarts.nl</a>.
                Gebruik de patientenomgeving voor niet-urgente vragen (reactietijd 3 werkdagen).
              </p>
            </div>
          </div>
        </div>

        <!-- Praktijksluitingen -->
        <div class="bg-blue-50 border-l-4 border-blue-400 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            <div>
              <h3 class="font-semibold text-blue-900 text-sm">Praktijksluitingen april/mei 2026</h3>
              <ul class="text-sm text-blue-800 mt-2 space-y-1">
                <li>Van der Eem: 20 april -- 27 april</li>
                <li>Steketee: 20 april -- 28 april</li>
                <li>Duijn: 27 april -- 5 mei</li>
                <li>Louwet: 30 april -- 4 mei</li>
              </ul>
              <p class="text-xs text-blue-600 mt-2">Telefonisch contact blijft mogelijk voor niet-spoedeisende zaken.</p>
            </div>
          </div>
        </div>

        <!-- Afsprakenbeleid -->
        <div class="bg-neutral-50 border-l-4 border-neutral-300 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
            </svg>
            <div>
              <h3 class="font-semibold text-neutral-800 text-sm">Afspraken maken</h3>
              <p class="text-sm text-neutral-600 mt-1">
                Aan de balie kunnen geen afspraken worden ingepland. Maak afspraken telefonisch of via de patientenomgeving, ter bescherming van uw privacy.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practices -->
  <section class="py-16 lg:py-24 bg-neutral-50" id="praktijken">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold">Onze praktijken</h2>
        <p class="mt-3 text-neutral-600 max-w-2xl mx-auto">
          Vier huisartsen, elk met een eigen team van assistenten en verpleegkundigen.
          Elke praktijk heeft een eigen telefoonnummer.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 lg:gap-6">
        {practices.map((practice) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200 hover:shadow-md transition-shadow border-t-4 border-t-primary-400">
            <h3 class="text-lg font-bold text-neutral-900 mb-2">{practice.name}</h3>
            <div class="space-y-1 text-sm text-neutral-600 mb-4">
              {practice.doctors.map((doc) => (
                <p>
                  <span class="font-medium text-neutral-800">{doc.name}</span>
                  {doc.role !== 'Huisarts (hoofdpraktijk)' && (
                    <span class="text-neutral-400"> -- {doc.role}</span>
                  )}
                </p>
              ))}
            </div>
            <a href={`tel:${practice.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-1.5 text-dark-600 font-medium no-underline hover:text-dark-700 text-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {practice.phone}
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center space-y-1">
        <p class="text-sm text-neutral-500">
          <strong>Hoofdlijn:</strong> <a href="tel:023-5410345" class="no-underline hover:underline">023-541 03 45</a> &nbsp;|&nbsp;
          <strong>Open:</strong> Ma-vr 08:00 -- 17:00 (avondspreekuur op afspraak)
        </p>
        <p class="text-sm text-neutral-500">
          <strong>Adres:</strong> Pijnboomstraat 19, 2023 VN Haarlem &nbsp;|&nbsp;
          <strong>E-mail:</strong> <a href="mailto:info@schoterpoort.com" class="no-underline hover:underline">info@schoterpoort.com</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="py-10 bg-accent-50 border-y border-accent-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
        <div class="w-14 h-14 rounded-full bg-accent-100 flex items-center justify-center shrink-0">
          <svg class="w-7 h-7 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <div class="text-center md:text-left">
          <h2 class="text-xl font-bold text-neutral-900 mb-1">Spoed buiten openingstijden?</h2>
          <p class="text-neutral-600 text-sm mb-3">
            Bel de Spoedpost Haarlem voor avond-, nacht- en weekendzorg. Bij levensbedreiging: bel 112.
          </p>
          <a
            href="tel:023-7504567"
            class="inline-flex items-center gap-2 bg-accent-600 text-white font-semibold px-5 py-2.5 rounded-lg no-underline hover:bg-accent-700 transition-colors"
          >
            Bel 023-750 45 67
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="py-16 lg:py-24 bg-neutral-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold">Nieuws</h2>
          <a href="/nieuws" class="text-sm text-dark-600 hover:text-dark-700 no-underline font-medium">Alle berichten &rarr;</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {news.map((article) => (
            <a
              href={`/nieuws/${article.id}`}
              class="block bg-white rounded-xl border border-neutral-200 p-5 hover:border-primary-300 hover:shadow-md transition-all no-underline group"
            >
              <time class="text-xs text-neutral-400">
                {article.data.date.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="font-bold text-neutral-900 group-hover:text-dark-600 mt-1 text-sm">{article.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Telefonisch consult & Afspraak afzeggen -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Telefonisch consult -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-900 mb-1">Telefonisch consult</h3>
              <p class="text-sm text-neutral-600">'s Ochtends terugbelafspraken voor telefonisch consult met de huisarts later op de dag.</p>
            </div>
          </div>
        </div>
        <!-- Afspraak afzeggen -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-900 mb-1">Afspraak afzeggen</h3>
              <p class="text-sm text-neutral-600">Wij verzoeken u dringend om uw afspraak uiterlijk 24 uur van tevoren telefonisch af te zeggen. Voor afspraken bij de praktijkondersteuner GGZ: minimaal 48 uur van tevoren afzeggen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Kwaliteit & Team -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Kwaliteit</h2>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex flex-col md:flex-row gap-6">
          <!-- NPA keurmerk -->
          <div class="flex-1 bg-primary-50 rounded-xl p-6 border border-primary-100">
            <h3 class="font-bold text-neutral-900 mb-2">NPA-keurmerk sinds 2006</h3>
            <p class="text-sm text-neutral-700">De praktijk heeft sinds 2006 het NPA-kwaliteitskeurmerk, begin 2025 opnieuw verlengd voor drie jaar. Patienttevredenheidsscores zijn consequent 8,5 tot 9 uit 10 voor artsen, personeel, service en organisatie.</p>
          </div>
          <!-- Team -->
          <div class="flex-1 bg-neutral-50 rounded-xl p-6 border border-neutral-200">
            <h3 class="font-bold text-neutral-900 mb-2">10 artsen, 1 team</h3>
            <p class="text-sm text-neutral-700">De vier huisartsen (Louwet, Duijn, Steketee, Van der Eem) vormen een maatschap met 4 huisartsen in loondienst en 2 huisartsen in opleiding, in totaal 10 artsen. De praktijk is een erkende opleidingspraktijk voor AMC (UMC Amsterdam) huisartsen in opleiding en coassistenten.</p>
          </div>
        </div>
        <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
          <p class="text-sm text-neutral-700">De praktijk legt de nadruk op servicegerichtheid, samenwerking en het bieden van patientenzorg op hoog niveau. Patienten worden ingeschreven bij een van de vier praktijkhouders en werken met een vast team van huisarts, assistente en praktijkverpleegkundige. De praktijk coordineert zorg met specialisten, ziekenhuizen, apothekers, fysiotherapeuten, psychologen en wijkverpleegkundigen. Avond-, weekend- en nachtdiensten worden verzorgd via de Huisartsen-Spoedpost.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wist u dat? -->
  <section class="py-16 lg:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Wist u dat?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { text: 'U hoeft zich niet te melden bij de balie voor geplande afspraken; wacht in de wachtkamer van uw huisarts of behandelaar', icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z' },
