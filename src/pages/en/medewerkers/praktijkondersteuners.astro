---
import PageLayout from '../../../layouts/PageLayout.astro';
import StaffCard from '../../../components/staff/StaffCard.astro';
import allStaff from '../../../data/staff.json';
import { getEntry, render } from 'astro:content';
import { url } from '../../../utils/url';

const nurses = allStaff.filter((s) => s.role === 'Praktijkverpleegkundige somatiek');
const supportNurse = allStaff.filter((s) => s.role === 'Spreekuurondersteuner');
const pohGgz = allStaff.filter((s) => s.role === 'Praktijkondersteuner GGZ');
const practiceManager = allStaff.filter((s) => s.role === 'Praktijkmanager');

const pageEntry = await getEntry('pages-en', 'praktijkondersteuners');
const somatiekEntry = await getEntry('pages-en', 'praktijkondersteuners-somatiek');
const sprondEntry = await getEntry('pages-en', 'praktijkondersteuners-spreekuurondersteuner');
const ggzEntry = await getEntry('pages-en', 'praktijkondersteuners-ggz');
const { Content: SomatiekContent } = await render(somatiekEntry!);
const { Content: SprondContent } = await render(sprondEntry!);
const { Content: GgzContent } = await render(ggzEntry!);

// Translation maps
const dayMap: Record<string, string> = {
  'maandag': 'Monday', 'dinsdag': 'Tuesday', 'woensdag': 'Wednesday',
  'donderdag': 'Thursday', 'donderdagochtend': 'Thursday morning',
  'vrijdag': 'Friday',
};
const roleTranslationsFallback: Record<string, string> = {
  'Praktijkverpleegkundige somatiek': 'Practice nurse (somatic)',
  'Spreekuurondersteuner': 'Consultation support',
  'Praktijkondersteuner GGZ': 'Mental health support worker (POH-GGZ)',
};
function translateRole(member: any): string {
  return (member as any).roleEn || roleTranslationsFallback[member.role] || member.role;
}
function translateDays(days?: string[]): string[] | undefined {
  return days?.map((d) => dayMap[d] || d);
}
---

<PageLayout
  title={pageEntry!.data.title}
  description={pageEntry!.data.description}
  lang="en"
>
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm">
        <a href={url('/en/medewerkers')} class="text-dark-600 hover:text-dark-700 no-underline">&larr; Staff</a>
      </nav>

      <h1 class="text-3xl lg:text-4xl font-bold mb-8">{pageEntry!.data.title}</h1>

      <!-- Practice nurses (somatic) -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Practice nurses (somatic)</h2>
        <SomatiekContent />
      </article>

      {nurses.length > 0 && (
        <div class="grid gap-4 mb-12">
          {nurses.map((member) => (
            <StaffCard
              name={member.name}
              role={translateRole(member)}
              team={member.team}
              photo={(member as any).photo}
              workingDays={translateDays(member.workingDays)}
              since={(member as any).sinceEn || (member as any).since}
              background={(member as any).backgroundEn || (member as any).background}
              specializations={(member as any).specializationsEn || (member as any).specializations}
              interests={(member as any).interestsEn || (member as any).interests}
              bigNumber={(member as any).bigNumber}
              lang="en"
            />
          ))}
        </div>
      )}

      <!-- Consultation support -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Consultation support</h2>
        <SprondContent />
      </article>

      {supportNurse.length > 0 && (
        <div class="grid gap-4 mb-12">
          {supportNurse.map((member) => (
            <StaffCard
              name={member.name}
              role={translateRole(member)}
              photo={(member as any).photo}
              workingDays={translateDays(member.workingDays)}
              since={(member as any).sinceEn || (member as any).since}
              background={(member as any).backgroundEn || (member as any).background}
              specializations={(member as any).specializationsEn || (member as any).specializations}
              interests={(member as any).interestsEn || (member as any).interests}
              bigNumber={(member as any).bigNumber}
              lang="en"
            />
          ))}
        </div>
      )}

      <!-- Mental health practice support workers (POH-GGZ) -->
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-6">
        <h2>Mental health practice support workers (POH-GGZ)</h2>
        <GgzContent />
      </article>

      {pohGgz.length > 0 && (
        <div class="grid gap-4 mb-12">
          {pohGgz.map((member) => (
            <StaffCard
              name={member.name}
              role={translateRole(member)}
              team={member.team}
              photo={(member as any).photo}
              workingDays={translateDays(member.workingDays)}
              since={(member as any).sinceEn || (member as any).since}
              background={(member as any).backgroundEn || (member as any).background}
              specializations={(member as any).specializationsEn || (member as any).specializations}
              interests={(member as any).interestsEn || (member as any).interests}
              bigNumber={(member as any).bigNumber}
              lang="en"
            />
          ))}
        </div>
      )}

      {practiceManager.length > 0 && (
        <>
          <h2 class="text-2xl font-bold mb-4">Practice manager</h2>
          <div class="grid gap-4">
            {practiceManager.map((member) => (
              <StaffCard
                name={member.name}
                role={translateRole(member)}
                team={member.team}
                photo={(member as any).photo}
                workingDays={translateDays(member.workingDays)}
                since={(member as any).sinceEn || (member as any).since}
                background={(member as any).backgroundEn || (member as any).background}
                specializations={(member as any).specializationsEn || (member as any).specializations}
                interests={(member as any).interestsEn || (member as any).interests}
                bigNumber={(member as any).bigNumber}
                lang="en"
              />
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</PageLayout>
