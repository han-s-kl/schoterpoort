---
import PageLayout from '../../../layouts/PageLayout.astro';
import StaffCard from '../../../components/staff/StaffCard.astro';
import { getCollection, render } from 'astro:content';
import allStaff from '../../../data/staff.json';
import { url } from '../../../utils/url';

export async function getStaticPaths() {
  const pages = await getCollection('pages-en');
  // praktijkondersteuners has its own dedicated page file so it is
  // intentionally excluded from this catch-all.
  return ['huisartsen', 'praktijkassistenten', 'huisartsen-in-opleiding']
    .map((slug) => {
      const page = pages.find((p) => p.id === slug);
      return page ? { params: { slug }, props: { page, slug } } : null;
    })
    .filter(Boolean);
}

const { page, slug } = Astro.props;
const { Content } = await render(page);

// Filter staff by role category
const roleMap: Record<string, string[]> = {
  'huisartsen': ['Huisarts'],
  'praktijkassistenten': ['Doktersassistente', 'Baliemedewerker', 'Spreekuurondersteuner'],
  'huisartsen-in-opleiding': ['Huisarts in opleiding'],
};

const roles = roleMap[slug] || [];
const staffForPage = allStaff.filter((s) => {
  if (slug === 'huisartsen') {
    return s.role === 'Huisarts';
  }
  return roles.some((r) => s.role.includes(r));
});
// Override role display for staff that appear on multiple pages.
// An empty string hides the role line entirely (e.g. Marjoleine on the
// praktijkassistenten page only shows her team "Praktijk Duijn").
const roleOverrides: Record<string, Record<string, string>> = {
  'praktijkassistenten': { 'Spreekuurondersteuner': '' },
};
const overrides = roleOverrides[slug] || {};

// Translation maps for English
const dayMap: Record<string, string> = {
  'maandag': 'Monday', 'dinsdag': 'Tuesday', 'woensdag': 'Wednesday',
  'donderdag': 'Thursday', 'donderdagochtend': 'Thursday morning',
  'vrijdag': 'Friday', 'zaterdag': 'Saturday', 'zondag': 'Sunday',
};
// Fallback map for roles not yet auto-translated
const roleTranslationsFallback: Record<string, string> = {
  'Huisarts': 'GP',
  'Praktijkverpleegkundige somatiek': 'Practice nurse (somatic)',
  'Spreekuurondersteuner': 'Consultation support',
  'Praktijkondersteuner GGZ': 'Mental health support worker (POH-GGZ)',
  'Praktijkmanager': 'Practice manager',
  'Baliemedewerker': 'Front desk staff',
  'Baliemedewerker / Administratief': 'Front desk / Administrative',
  'Doktersassistente': 'Medical assistant',
  'Huisarts in opleiding (HAIO)': 'GP trainee (HAIO)',
};
function translateRole(member: any): string {
  return (member as any).roleEn || roleTranslationsFallback[member.role] || member.role;
}
function translateDays(days?: string[]): string[] | undefined {
  return days?.map((d) => dayMap[d] || d);
}

const hasStaffCards = staffForPage.length > 0;
---

<PageLayout title={page.data.title} description={page.data.description} lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm">
        <a href={url('/en/medewerkers')} class="text-dark-600 hover:text-dark-700 no-underline">&larr; Staff</a>
      </nav>

      <h1 class="text-3xl lg:text-4xl font-bold mb-8">{page.data.title}</h1>

      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline mb-8">
        <Content />
      </article>

      {hasStaffCards && (
        <div class="grid gap-4">
          {staffForPage.map((member) => (
            <StaffCard
              name={member.name}
              role={member.role in overrides
                ? (roleTranslationsFallback[overrides[member.role]] || overrides[member.role])
                : translateRole(member)}
              team={slug === 'huisartsen' ? undefined : member.team}
              photo={(member as any).photo}
              workingDays={translateDays(member.workingDays)}
              since={(member as any).sinceEn || (member as any).since}
              background={(member as any).backgroundEn || (member as any).background}
              specializations={(member as any).specializationsEn || (member as any).specializations}
              interests={(member as any).interestsEn || (member as any).interests}
              phone={(member as any).phone}
              bigNumber={(member as any).bigNumber}
              lang="en"
            />
          ))}
        </div>
      )}
    </div>
  </section>
</PageLayout>
