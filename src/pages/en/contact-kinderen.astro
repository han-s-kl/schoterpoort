---
import PageLayout from '../../layouts/PageLayout.astro';
import practiceData from '../../data/practices.json';
import { url } from '../../utils/url';
---

<PageLayout title="Contact for children" description="Secure contact form for parents of children under 16 at Huisartsenpraktijk Schoterpoort." lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-6">Contact for children under 16</h1>

      <!-- Warnings -->
      <div class="space-y-3 mb-10">
        <div class="bg-accent-50 border-l-4 border-accent-400 rounded-r-lg p-4">
          <p class="text-sm text-accent-800 font-semibold">In case of emergency: call your GP directly or outside office hours the Emergency Post (<a href="tel:023-7504567" class="underline">023-750 45 67</a>). This form is not intended for urgent questions.</p>
        </div>
        <div class="bg-blue-50 border-l-4 border-blue-400 rounded-r-lg p-4">
          <p class="text-sm text-blue-800">Is your child <strong>16 years or older</strong>? Then your child can ask a question themselves via the <a href={url('/en/patientenomgeving')} class="underline font-medium">patient portal</a>.</p>
        </div>
        <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-lg p-4">
          <p class="text-sm text-amber-800"><strong>Important:</strong> Do not log in to your own patient portal to ask a question about your child. Your portal is linked to your own medical record, not your child's.</p>
        </div>
      </div>

      <!-- Explanation -->
      <div class="prose prose-neutral max-w-none mb-10">
        <p>
          For children under 16, you as a parent or guardian can send a secure message
          to the practice. To help your child as best as possible, we ask you to fill in the
          information below as completely as possible.
        </p>
        <p>
          The message is <strong>sent securely via ZIVVER</strong>, so your child's medical data
          is protected.
        </p>
      </div>

      <!-- Structured template -->
      <div class="bg-white rounded-xl border border-neutral-200 shadow-sm overflow-hidden mb-8">
        <div class="bg-primary-50 px-6 py-4 border-b border-primary-100">
          <h2 class="font-bold text-neutral-900 text-lg">Fill in the following details</h2>
          <p class="text-sm text-neutral-600 mt-1">Copy the template below and fill in the answers in your message.</p>
        </div>
        <div class="px-6 py-5">
          <div id="template-text" class="bg-neutral-50 rounded-lg p-5 font-mono text-sm text-neutral-700 space-y-3 border border-neutral-200">
            <p><strong>CHILD'S DETAILS</strong></p>
            <p>Child's name: ...</p>
            <p>Child's date of birth: ...</p>
            <p>Parent/guardian name: ...</p>
            <p>Phone number: ...</p>
            <p>GP: Louwet / Duijn / Steketee / Van der Eem <span class="text-neutral-400">(delete as appropriate)</span></p>
            <p>&nbsp;</p>
            <p><strong>MEDICAL QUESTION</strong></p>
            <p>What is your question?: ...</p>
            <p>What are the symptoms?: ...</p>
            <p>How long have the symptoms been present?: ...</p>
            <p>Does the child have a fever? (yes/no, if yes how many degrees?): ...</p>
            <p>Is the child taking any medication? (yes/no, if yes which?): ...</p>
            <p>Has there been previous contact about this complaint? (yes/no): ...</p>
            <p>&nbsp;</p>
            <p><strong>PHOTO (optional)</strong></p>
            <p>Would you like to include a photo? (yes/no): ...</p>
            <p>If yes -- on which part of the body was the photo taken?: ...</p>
            <p>Does the child have itching or pain at that location?: ...</p>
          </div>

          <button
            id="copy-template"
            class="mt-4 inline-flex items-center gap-2 bg-neutral-100 hover:bg-neutral-200 text-neutral-700 font-medium text-sm px-4 py-2 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
            </svg>
            Copy template
          </button>
        </div>
      </div>

      <!-- Send button -->
      <div class="bg-dark-50 rounded-xl p-6 border border-dark-200 text-center">
        <h2 class="font-bold text-neutral-900 text-lg mb-2">Send securely via ZIVVER</h2>
        <p class="text-sm text-neutral-600 mb-5">
          Click the button below to send a secure message. Paste the completed template
          into the message and optionally attach a photo.
        </p>
        <a
          href="https://app.zivver.com/conversation-starter/schoterpoort"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-dark-700 text-white font-semibold px-8 py-3.5 rounded-xl no-underline hover:bg-dark-800 transition-colors text-lg"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          Send secure message
        </a>
        <p class="text-xs text-neutral-400 mt-3">
          The ZIVVER link will be activated shortly. If you experience any issues, please contact the practice by phone.
        </p>
      </div>

      <!-- Alternative -->
      <div class="mt-8 text-sm text-neutral-500">
        <h3 class="font-semibold text-neutral-700 mb-2">Unable to use ZIVVER?</h3>
        <p>Call your GP's practice during office hours (Mon-Fri 08:00 -- 17:00):</p>
        <ul class="mt-2 space-y-1">
          {practiceData.practices.map((practice) => (
            <li>
              {practice.name}: <a href={`tel:${practice.phone.replace(/\s/g, '')}`} class="text-dark-600 no-underline">{practice.phone}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const btn = document.getElementById('copy-template');
  const template = document.getElementById('template-text');

  btn?.addEventListener('click', () => {
    const text = template?.innerText || '';
    navigator.clipboard.writeText(text).then(() => {
      if (btn) {
        const original = btn.innerHTML;
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg> Copied!';
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      }
    });
  });
</script>