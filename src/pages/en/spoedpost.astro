---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import practiceData from '../../data/practices.json';

const pages = await getCollection('pages-en');
const page = pages.find((p) => p.id === 'spoedpost');
const { Content } = await render(page!);

const spoedItem = practiceData.keuzemenu.find((item: any) => /spoed/i.test(item.label));
const spoedKey = spoedItem?.key || '1';
const ot = practiceData.openingstijden;
---

<PageLayout title={page!.data.title} description={page!.data.description} lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <h1 class="text-3xl font-bold text-neutral-900 mb-8">Emergency post / Out-of-hours care</h1>

      <div class="space-y-6 mb-10">
        <div class="bg-primary-50 rounded-xl p-6 border border-primary-200">
          <h2 class="font-bold text-neutral-900 mb-2">During office hours ({ot.daysShortEn} {ot.open}-{ot.close})</h2>
          <p class="text-sm text-neutral-700">Call the number of your own GP. Press {spoedKey} for life-threatening situations.</p>
          <p class="text-sm text-neutral-600 mt-2">In case of immediate danger: call <a href="tel:112" class="font-bold underline">112</a>.</p>
        </div>

        <div class="bg-accent-50 border-l-4 border-accent-400 rounded-r-lg p-5">
          <h2 class="font-bold text-accent-800 mb-2">Outside office hours</h2>
          <p class="text-sm text-accent-700">After {ot.close} and at weekends, call the GP Emergency Post: <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="font-semibold underline">{practiceData.phoneEmergency}</a></p>
          <p class="text-sm text-accent-600 mt-2">The Emergency Post provides care for health problems that need to be assessed within a few hours and cannot wait until the next working day. Only walk in without an appointment for serious injuries or complaints.</p>
        </div>
        <div class="bg-red-50 border-2 border-red-300 rounded-xl p-5 text-center">
          <p class="text-sm font-bold text-red-800">Life-threatening emergencies: always call <a href="tel:112" class="underline">112</a></p>
        </div>
      </div>

      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </article>
    </div>
  </section>
</PageLayout>
