---
import PageLayout from '../../layouts/PageLayout.astro';
import PracticeCard from '../../components/PracticeCard.astro';
import practiceData from '../../data/practices.json';
import spreekuurData from '../../data/spreekuur-en.json';
import { url } from '../../utils/url';

const practices = practiceData.practices;
const spoedItem = practiceData.keuzemenu.find((item: any) => /spoed/i.test(item.label));
const spoedKey = spoedItem?.key || '1';
---

<PageLayout title={spreekuurData.pageTitle || 'Appointments'} description={spreekuurData.pageDescription || 'Make an appointment at Huisartsenpraktijk Schoterpoort Haarlem.'} lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-8">{spreekuurData.pageTitle || 'Appointments'}</h1>

      <!-- How to book an appointment -->
      <div class="bg-primary-50 rounded-xl p-6 border border-primary-200 mb-10">
        <h2 class="text-xl font-bold text-neutral-900 mb-4">How do I book an appointment?</h2>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-900">By phone</p>
              <p class="text-sm text-neutral-600">Call the direct number of your own GP (see below).</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-900">Via the patient portal</p>
              <p class="text-sm text-neutral-600">
                Book appointments online, send e-consultations and view results.
                <a href={url('/en/patientenomgeving')} class="text-dark-600 font-medium">Go to patient portal &rarr;</a>
              </p>
            </div>
          </div>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 ml-11">
            <p class="text-xs text-amber-800">Appointments cannot be made at the reception desk, to protect your privacy.</p>
          </div>
        </div>
      </div>

      <!-- Practice cards with phone numbers -->
      <h2 class="text-xl font-bold mb-4">Call your GP</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        {practices.map((practice) => (
          <PracticeCard practice={practice} showWorkingDays={true} />
        ))}
      </div>

      <!-- Opening hours -->
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-bold text-neutral-900 mb-3">Opening hours</h3>
          <ul class="text-sm text-neutral-600 space-y-2">
            <li class="flex justify-between"><span>{practiceData.openingstijden.daysEn}</span> <span class="font-medium text-neutral-800">{practiceData.openingstijden.open} -- {practiceData.openingstijden.close}</span></li>
            {practiceData.avondspreekuur.enabled && (
              <li class="flex justify-between"><span>Evening consultation</span> <span class="font-medium text-neutral-800">{practiceData.avondspreekuur.time} ({practiceData.avondspreekuur.frequency})</span></li>
            )}
          </ul>
          {practiceData.avondspreekuur.enabled && (
            <p class="text-xs text-neutral-400 mt-3">{practiceData.avondspreekuur.noteEn}</p>
          )}
          <p class="text-xs text-neutral-400 mt-1">{practiceData.openingstijden.lunchNoteEn}</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-bold text-neutral-900 mb-3">Phone menu</h3>
          <ul class="text-sm text-neutral-600 space-y-2">
            {practiceData.keuzemenu.map((item) => (
              <li><span class="font-mono bg-neutral-100 px-1.5 py-0.5 rounded text-xs">{item.key}</span> {(item as any).labelEn || item.label}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Types of appointments -->
      <h2 class="text-xl font-bold mb-4">Types of appointments</h2>
      {spreekuurData.soortenIntro && (
        <p class="text-sm text-neutral-600 mb-4" set:html={spreekuurData.soortenIntro} />
      )}
      <div class="grid sm:grid-cols-2 gap-4 mb-10">
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Standard consultation</h3>
          <p class="text-sm text-neutral-600" set:html={spreekuurData.standaardConsult} />
        </div>
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Double consultation</h3>
          <p class="text-sm text-neutral-600" set:html={spreekuurData.dubbelConsult} />
        </div>
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Urgent appointment</h3>
          <p class="text-sm text-neutral-600" set:html={spreekuurData.spoedafspraak} />
        </div>
        <div class="bg-white rounded-xl p-5 border border-neutral-200">
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Video consultation</h3>
          <p class="text-sm text-neutral-600" set:html={spreekuurData.videoconsult} />
        </div>
      </div>

      <!-- Callback appointments -->
      <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200 mb-6">
        <h2 class="font-bold text-neutral-900 mb-2">Callback appointments</h2>
        <p class="text-sm text-neutral-600" set:html={spreekuurData.terugbelafspraken} />
      </div>

      <!-- Cancel appointment -->
      <div class="bg-accent-50 rounded-xl p-6 border border-accent-200 mb-10">
        <h2 class="font-bold text-accent-800 mb-2">Cancel an appointment</h2>
        <p class="text-sm text-accent-700" set:html={spreekuurData.afspraakAfzeggen} />
      </div>

      <!-- Emergency -->
      <div class="bg-accent-50 border-l-4 border-accent-400 rounded-r-lg p-5">
        <h2 class="font-bold text-accent-800 mb-2">Emergency</h2>
        <ul class="text-sm text-accent-700 space-y-1">
          <li>During office hours: call your GP, option {spoedKey}</li>
          <li>After 17:00, weekends and holidays: <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="font-semibold underline">{practiceData.phoneEmergency}</a> (Emergency GP Post, <a href={url('/en/spoedpost')} class="underline">more info</a>)</li>
          <li>Life-threatening: <a href="tel:112" class="font-bold underline">112</a></li>
        </ul>
      </div>
    </div>
  </section>
</PageLayout>
