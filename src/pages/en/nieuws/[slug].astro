---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { url } from '../../../utils/url';

export async function getStaticPaths() {
  const news = await getCollection('news-en');
  return news.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<PageLayout title={article.data.title} description={article.data.description} lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm">
        <a href={url('/en/nieuws')} class="text-dark-600 hover:text-dark-700 no-underline">&larr; Back to news</a>
      </nav>
      <article>
        <header class="mb-8">
          <time class="text-sm text-neutral-400">
            {article.data.date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          <h1 class="text-3xl lg:text-4xl font-bold mt-2">{article.data.title}</h1>
        </header>
        <div class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600">
          <Content />
        </div>
      </article>
    </div>
  </section>
</PageLayout>
