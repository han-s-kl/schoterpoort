---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import practiceData from '../../data/practices.json';

const pages = await getCollection('pages-en');
const page = pages.find((p) => p.id === 'herhaalrecept');
const { Content } = await render(page!);

const recept = practiceData.keuzemenu.find((item: any) => /recept/i.test(item.label));
const receptKey = recept?.key || '2';
---

<PageLayout title={page!.data.title} description={page!.data.description} lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />

        <h2>2. Via the prescription line (telephone)</h2>
        <p>Call the practice phone number of your own GP and select <strong>option {receptKey}</strong>.</p>
        <ul>
          {practiceData.practices.map((practice: any) => (
            <li>{practice.name}: <a href={`tel:${practice.phone.replace(/[\s-]/g, '')}`}>{practice.phone}</a></li>
          ))}
        </ul>

        <p>The prescription line will automatically ask you the following questions:</p>
        <ul>
          <li>The name of your GP</li>
          <li>Name and date of birth of the person the prescription is intended for</li>
          <li>Street and house number of the home address</li>
          <li>Name(s) of the medication you are ordering (have the boxes to hand!)</li>
          <li>Name of your pharmacy</li>
        </ul>

        <h2>Which medication can you request?</h2>
        <p>You can only request prescriptions for medication that you use <strong>chronically</strong> (usually daily) on the advice of your GP or specialist.</p>
        <p>If you wish to request medication for newly occurring complaints or temporary medication -- which you received for a specific period -- you <strong>cannot</strong> order these through the prescription line or website. For this, you can call the practice assistant during office hours; if necessary, your GP will be consulted about the request.</p>

        <h2>When will your medication be ready?</h2>
        <p>If you leave a message on the prescription line or order a prescription via the website <strong>before 12:00 noon</strong>, you can collect your medication from your pharmacy <strong>2 working days later</strong> (they will be ready from 15:00).</p>
        <p>Examples:</p>
        <ul>
          <li>If you call/email on Tuesday evening, your medication will be ready at the pharmacy on <strong>Friday</strong>.</li>
          <li>If you call/email on Friday afternoon after 12:00 or at the weekend, you can collect your medication on <strong>Wednesday after 15:00</strong>.</li>
        </ul>
      </article>
    </div>
  </section>
</PageLayout>
