---
import PageLayout from '../../layouts/PageLayout.astro';
import practiceData from '../../data/practices.json';
import data from '../../data/herhaalrecept-en.json';

const recept = practiceData.keuzemenu.find((item: any) => /recept/i.test(item.label));
const receptKey = recept?.key || '2';
---

<PageLayout title="Repeat prescription" description="Information about requesting repeat prescriptions at Huisartsenpraktijk Schoterpoort." lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <h1>Requesting a repeat prescription</h1>
        <p set:html={data.intro} />

        <h2>1. Via the patient portal</h2>
        <p set:html={data.patientenomgeving} />

        <h2>2. Via the prescription line (telephone)</h2>
        <p>{data.receptenlijn} Select <strong>option {receptKey}</strong>.</p>
        <ul>
          {practiceData.practices.map((practice: any) => (
            <li>{practice.name}: <a href={`tel:${practice.phone.replace(/[\s-]/g, '')}`}>{practice.phone}</a></li>
          ))}
        </ul>
        <p>The prescription line will automatically ask you the following questions:</p>
        <ul>
          {data.receptenlijnVragen.map((v: string) => <li>{v}</li>)}
        </ul>

        <h2>Which medication can you request?</h2>
        <p set:html={data.welkeMedicijnen} />

        <h2>When will your medication be ready?</h2>
        <p set:html={data.wanneerKlaar} />
        <p>Examples:</p>
        <ul>
          {data.wanneerKlaarVoorbeelden.map((v: string) => <li set:html={v} />)}
        </ul>
      </article>
    </div>
  </section>
</PageLayout>
