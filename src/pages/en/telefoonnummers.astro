---
import PageLayout from '../../layouts/PageLayout.astro';
import PracticeCard from '../../components/PracticeCard.astro';
import practiceData from '../../data/practices.json';
import spreekuurData from '../../data/spreekuur-en.json';
import { url } from '../../utils/url';
---

<PageLayout title="Phone numbers" description="All phone numbers for Huisartsenpraktijk Schoterpoort Haarlem." lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-8">Phone numbers</h1>

      <!-- Practice numbers -->
      <h2 class="text-xl font-bold mb-4">Direct lines per practice</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        {practiceData.practices.map((practice) => (
          <PracticeCard practice={practice} />
        ))}
      </div>

      <!-- Phone menu -->
      <div class="bg-white rounded-xl p-5 border border-neutral-200 mb-8">
        <h3 class="font-bold text-neutral-900 mb-3">Phone menu</h3>
        <ul class="text-sm text-neutral-600 space-y-2">
          {practiceData.keuzemenu.map((item) => (
            <li><span class="font-mono bg-neutral-100 px-1.5 py-0.5 rounded text-xs">{item.key}</span> {(item as any).labelEn || item.label}</li>
          ))}
        </ul>
      </div>

      <!-- Callback appointments -->
      <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200 mb-8">
        <h2 class="font-bold text-neutral-900 mb-2">Callback appointments</h2>
        <p class="text-sm text-neutral-600" set:html={spreekuurData.terugbelafspraken} />
      </div>

      <!-- Main number -->
      <div class="bg-primary-50 rounded-xl p-6 border border-primary-200 mb-8">
        <h2 class="font-bold text-lg text-neutral-900 mb-2">General number</h2>
        <a href={`tel:${practiceData.phoneGeneral.replace(/[\s-]/g, '')}`} class="text-2xl font-bold text-dark-700 no-underline hover:text-dark-800">
          {practiceData.phoneGeneral}
        </a>
        <p class="text-sm text-neutral-600 mt-2">{practiceData.openingstijden.daysShortEn} {practiceData.openingstijden.open} -- {practiceData.openingstijden.close}. {practiceData.openingstijden.lunchNoteEn}</p>
      </div>

      <!-- Other numbers -->
      <h2 class="text-xl font-bold mb-4">Other numbers</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between bg-white rounded-lg border border-neutral-200 p-4">
          <div>
            <span class="text-sm text-neutral-700">Practice nurses</span>
            <p class="text-xs text-neutral-500">Only reachable between 11:00 and 12:00</p>
          </div>
          <a href={`tel:${practiceData.phoneNurses.replace(/\s/g, '')}`} class="font-medium text-dark-600 no-underline">{practiceData.phoneNurses}</a>
        </div>
        <div class="bg-accent-50 rounded-lg border border-accent-200 p-4">
          <span class="text-sm font-semibold text-neutral-900">Emergency during office hours: call your GP, option 1</span>
        </div>
        <div class="flex items-center justify-between bg-accent-50 rounded-lg border border-accent-200 p-4">
          <div>
            <span class="text-sm font-semibold text-neutral-900">Emergency Post (outside office hours)</span>
            <p class="text-xs text-neutral-500">Evenings, nights, weekends, and public holidays</p>
            <a href={url('/en/spoedpost')} class="text-xs text-accent-700 hover:text-accent-800 underline">More info about the Spoedpost</a>
          </div>
          <a href={`tel:${practiceData.phoneEmergency.replace(/\s/g, '')}`} class="font-bold text-accent-600 no-underline">{practiceData.phoneEmergency}</a>
        </div>
        <div class="flex items-center justify-between bg-accent-50 rounded-lg border border-accent-200 p-4">
          <span class="text-sm font-bold text-neutral-900">Life-threatening emergency</span>
          <a href="tel:112" class="font-bold text-accent-700 no-underline text-lg">112</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>