---
import PageLayout from '../../layouts/PageLayout.astro';
import { url } from '../../utils/url';
---

<PageLayout title="Complaints form" description="Submit a complaint at Huisartsenpraktijk Schoterpoort." lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-4">Complaints form</h1>

      <p class="text-neutral-600 mb-8">
        Do you have a complaint? You can use the complaints form below.
        Fill in your complaint and you will receive a response as soon as possible.
      </p>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
        <p class="text-sm text-amber-800"><strong>Note:</strong> This form opens your email client. The form will become fully online once the site is on its permanent hosting.</p>
      </div>

      <form
        action={`mailto:info@schoterpoort.com?subject=Complaint via website`}
        method="POST"
        enctype="text/plain"
        class="space-y-5"
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="voornaam" class="block text-sm font-medium text-neutral-700 mb-1">First name</label>
            <input
              type="text"
              id="voornaam"
              name="First name"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
          <div>
            <label for="achternaam" class="block text-sm font-medium text-neutral-700 mb-1">Surname <span class="text-accent-500">*</span></label>
            <input
              type="text"
              id="achternaam"
              name="Surname"
              required
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
        </div>

        <div>
          <label for="adres" class="block text-sm font-medium text-neutral-700 mb-1">Address</label>
          <input
            type="text"
            id="adres"
            name="Address"
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="postcode" class="block text-sm font-medium text-neutral-700 mb-1">Postcode</label>
            <input
              type="text"
              id="postcode"
              name="Postcode"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
          <div>
            <label for="plaats" class="block text-sm font-medium text-neutral-700 mb-1">City</label>
            <input
              type="text"
              id="plaats"
              name="City"
              class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
            />
          </div>
        </div>

        <div>
          <label for="telefoon" class="block text-sm font-medium text-neutral-700 mb-1">Telephone <span class="text-accent-500">*</span></label>
          <input
            type="tel"
            id="telefoon"
            name="Telephone"
            required
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email address <span class="text-accent-500">*</span></label>
          <input
            type="email"
            id="email"
            name="Email"
            required
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none"
          />
        </div>

        <div>
          <label for="klacht" class="block text-sm font-medium text-neutral-700 mb-1">Your complaint <span class="text-accent-500">*</span></label>
          <textarea
            id="klacht"
            name="Your complaint"
            required
            rows="6"
            class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-primary-400 focus:ring-1 focus:ring-primary-400 outline-none resize-y"
          ></textarea>
        </div>

        <div class="flex items-center justify-between pt-2">
          <p class="text-xs text-neutral-400"><span class="text-accent-500">*</span> Required field</p>
          <button
            type="submit"
            class="bg-dark-700 text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-dark-800 transition-colors text-sm"
          >
            Submit
          </button>
        </div>
      </form>

      <p class="text-xs text-neutral-400 mt-6">
        More information about our complaints procedure can be found on the <a href={url('/en/klachtenregeling')} class="underline">complaints procedure</a> page.
      </p>
    </div>
  </section>
</PageLayout>
