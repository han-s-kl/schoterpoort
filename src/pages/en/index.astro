---
import PageLayout from '../../layouts/PageLayout.astro';
import practiceData from '../../data/practices.json';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const news = (await getCollection('news-en'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const practices = practiceData.practices;
---

<PageLayout title="Home" lang="en">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-800 via-dark-700 to-dark-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(196,175,97,0.3),transparent_60%)]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="max-w-2xl">
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white">
          General Practice<br />
          <span class="text-primary-400">Schoterpoort</span>
        </h1>
        <p class="mt-6 text-lg text-dark-200 leading-relaxed">
          Four GPs, personal care. We are an NPA-certified group practice
          in Haarlem with patient satisfaction scores of 8.5 to 9.
        </p>
        <p class="mt-3 text-sm text-dark-300">
          <em>Welkom bij Huisartsenpraktijk Schoterpoort. Voor informatie in het Nederlands, bezoek onze <a href={url('/')} class="text-primary-300 underline hover:text-primary-200">Nederlandse pagina</a>.</em>
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={url('/en/telefoonnummers')}
            class="inline-flex items-center gap-2 bg-primary-400 text-dark-900 font-semibold px-6 py-3 rounded-xl no-underline hover:bg-primary-300 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Call us
          </a>
          <a
            href={url('/en/spreekuur')}
            class="inline-flex items-center gap-2 bg-white/10 text-white font-semibold px-6 py-3 rounded-xl no-underline hover:bg-white/20 transition-colors border border-white/20"
          >
            Book an appointment
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick actions -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-4">
        {[
          { label: 'Consultation hours', href: '/en/spreekuur', icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5' },
          { label: 'Repeat prescription', href: '/en/herhaalrecept', icon: 'M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859' },
          { label: 'Patient portal', href: '/en/patientenomgeving', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
          { label: 'Phone numbers', href: '/en/telefoonnummers', icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z' },
          { label: 'Emergency GP post', href: '/en/spoedpost', icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z' },
        ].map((action) => (
          <a
            href={url(action.href)}
            class="flex flex-col items-center gap-2 bg-white rounded-xl p-4 md:p-5 shadow-md hover:shadow-lg transition-shadow no-underline text-center border border-neutral-100"
          >
            <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={action.icon} />
              </svg>
            </div>
            <span class="text-sm font-medium text-neutral-700">{action.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Current announcements -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold mb-6">Current announcements</h2>
      <div class="space-y-4">
        <!-- Staff shortage -->
        <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
              <h3 class="font-semibold text-amber-900 text-sm">Staff shortage due to illness</h3>
              <p class="text-sm text-amber-800 mt-1">
                Due to illness, we have a limited assistant team. Please first check
                <a href="https://www.moetiknaardedokter.nl/" target="_blank" rel="noopener" class="font-medium underline">moetiknaardedokter.nl</a> or
                <a href="https://www.thuisarts.nl/" target="_blank" rel="noopener" class="font-medium underline">thuisarts.nl</a>.
                Use the patient portal for non-urgent questions (response time 3 working days).
              </p>
            </div>
          </div>
        </div>

        <!-- Practice closures -->
        <div class="bg-blue-50 border-l-4 border-blue-400 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            <div>
              <h3 class="font-semibold text-blue-900 text-sm">Practice closures April/May 2026</h3>
              <ul class="text-sm text-blue-800 mt-2 space-y-1">
                <li>Van der Eem: 20 April -- 27 April</li>
                <li>Steketee: 20 April -- 28 April</li>
                <li>Duijn: 27 April -- 5 May</li>
                <li>Louwet: 30 April -- 4 May</li>
              </ul>
              <p class="text-xs text-blue-600 mt-2">Telephone contact remains available for non-urgent matters.</p>
            </div>
          </div>
        </div>

        <!-- Appointment policy -->
        <div class="bg-neutral-50 border-l-4 border-neutral-300 rounded-r-lg p-5">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
            </svg>
            <div>
              <h3 class="font-semibold text-neutral-800 text-sm">Booking appointments</h3>
              <p class="text-sm text-neutral-600 mt-1">
                Appointments cannot be made at the reception desk. Please book appointments by phone or via the patient portal, to protect your privacy.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Practices -->
  <section class="py-16 lg:py-24 bg-neutral-50" id="praktijken">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold">Our practices</h2>
        <p class="mt-3 text-neutral-600 max-w-2xl mx-auto">
          Four GPs, each with their own team of assistants and nurses.
          Each practice has its own phone number.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 lg:gap-6">
        {practices.map((practice) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200 hover:shadow-md transition-shadow border-t-4 border-t-primary-400">
            <h3 class="text-lg font-bold text-neutral-900 mb-2">{practice.name}</h3>
            <div class="space-y-1 text-sm text-neutral-600 mb-4">
              {practice.doctors.map((doc) => (
                <p>
                  <span class="font-medium text-neutral-800">{doc.name}</span>
                  {doc.role !== 'Huisarts (hoofdpraktijk)' && (
                    <span class="text-neutral-400"> -- {doc.role}</span>
                  )}
                </p>
              ))}
            </div>
            <a href={`tel:${practice.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-1.5 text-dark-600 font-medium no-underline hover:text-dark-700 text-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {practice.phone}
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center space-y-1">
        <p class="text-sm text-neutral-500">
          <strong>General number:</strong> <a href="tel:023-5410345" class="no-underline hover:underline">023-541 03 45</a> &nbsp;|&nbsp;
          <strong>Open:</strong> Mon-Fri 08:00 -- 17:00 (evening consultations by appointment)
        </p>
        <p class="text-sm text-neutral-500">
          <strong>Address:</strong> Pijnboomstraat 19, 2023 VN Haarlem &nbsp;|&nbsp;
          <strong>Email:</strong> <a href="mailto:info@schoterpoort.com" class="no-underline hover:underline">info@schoterpoort.com</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="py-10 bg-accent-50 border-y border-accent-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
        <div class="w-14 h-14 rounded-full bg-accent-100 flex items-center justify-center shrink-0">
          <svg class="w-7 h-7 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <div class="text-center md:text-left">
          <h2 class="text-xl font-bold text-neutral-900 mb-1">Emergency outside office hours?</h2>
          <p class="text-neutral-600 text-sm mb-3">
            Call the Haarlem Emergency GP Post for evening, night and weekend care. Life-threatening emergency: call 112.
          </p>
          <a
            href="tel:023-7504567"
            class="inline-flex items-center gap-2 bg-accent-600 text-white font-semibold px-5 py-2.5 rounded-lg no-underline hover:bg-accent-700 transition-colors"
          >
            Call 023-750 45 67
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="py-16 lg:py-24 bg-neutral-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold">News</h2>
          <a href={url('/en/nieuws')} class="text-sm text-dark-600 hover:text-dark-700 no-underline font-medium">All articles &rarr;</a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {news.map((article) => (
            <a
              href={url(`/en/nieuws/${article.id}`)}
              class="block bg-white rounded-xl border border-neutral-200 p-5 hover:border-primary-300 hover:shadow-md transition-all no-underline group"
            >
              <time class="text-xs text-neutral-400">
                {article.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="font-bold text-neutral-900 group-hover:text-dark-600 mt-1 text-sm">{article.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Phone consultation & Cancel appointment -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Phone consultation -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-900 mb-1">Phone consultation</h3>
              <p class="text-sm text-neutral-600">Morning callback appointments for a phone consultation with the GP later in the day.</p>
            </div>
          </div>
        </div>
        <!-- Cancel appointment -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-accent-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-900 mb-1">Cancel an appointment</h3>
              <p class="text-sm text-neutral-600">We kindly ask you to cancel your appointment by phone at least 24 hours in advance. For appointments with the mental health practice nurse: at least 48 hours in advance.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quality & Team -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Quality</h2>
      </div>
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex flex-col md:flex-row gap-6">
          <!-- NPA accreditation -->
          <div class="flex-1 bg-primary-50 rounded-xl p-6 border border-primary-100">
            <h3 class="font-bold text-neutral-900 mb-2">NPA accreditation since 2006</h3>
            <p class="text-sm text-neutral-700">The practice has held the NPA quality accreditation since 2006, most recently renewed for three years in early 2025. Patient satisfaction scores are consistently 8.5 to 9 out of 10 for doctors, staff, service and organisation.</p>
          </div>
          <!-- Team -->
          <div class="flex-1 bg-neutral-50 rounded-xl p-6 border border-neutral-200">
            <h3 class="font-bold text-neutral-900 mb-2">10 doctors, 1 team</h3>
            <p class="text-sm text-neutral-700">The four GPs (Louwet, Duijn, Steketee, Van der Eem) form a partnership with 4 employed GPs and 2 GP trainees, totalling 10 doctors. The practice is an accredited training practice for UMC Amsterdam GP trainees and medical students.</p>
          </div>
        </div>
        <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
          <p class="text-sm text-neutral-700">The practice emphasises service orientation, collaboration and providing high-quality patient care. Patients are registered with one of the four practice owners and work with a dedicated team of GP, assistant and practice nurse. The practice coordinates care with specialists, hospitals, pharmacists, physiotherapists, psychologists and district nurses. Evening, weekend and night shifts are handled by the Emergency GP Post.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Did you know? -->
  <section class="py-16 lg:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold">Did you know?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { text: 'You do not need to check in at the reception desk for scheduled appointments; please wait in the waiting room of your GP or practitioner', icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z' },
          { text: 'Patient portal available for ordering prescriptions, e-consultations and booking appointments', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
          { text: 'Appointments only by phone or via the patient portal to protect your privacy', icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z' },
          { text: 'Assistants are trained in triage to provide appropriate care at the right time', icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z' },
          { text: 'A national shortage of medical assistants may cause longer telephone waiting times; the team appreciates your patience', icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' },
