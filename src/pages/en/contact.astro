---
import PageLayout from '../../layouts/PageLayout.astro';
import practiceData from '../../data/practices.json';
import { url } from '../../utils/url';
---

<PageLayout title="Contact" description="Get in touch with Huisartsenpraktijk Schoterpoort Haarlem." lang="en">
  <section class="py-12 lg:py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl lg:text-4xl font-bold mb-8 text-center">Get in touch</h1>

      <!-- Flow container -->
      <div id="contact-flow">
        <!-- Step 1: Emergency? -->
        <div id="step-1" class="flow-step">
          <div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-neutral-100 flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-neutral-900 mb-2">Is it an emergency?</h2>
            <p class="text-sm text-neutral-500 mb-6">Do you or your child have acute medical complaints that cannot wait?</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <button
                id="btn-spoed-ja"
                class="bg-accent-600 text-white font-semibold px-8 py-3 rounded-xl hover:bg-accent-700 transition-colors"
              >
                Yes, it is an emergency
              </button>
              <button
                id="btn-spoed-nee"
                class="bg-neutral-100 text-neutral-700 font-semibold px-8 py-3 rounded-xl hover:bg-neutral-200 transition-colors"
              >
                No, not an emergency
              </button>
            </div>
          </div>
        </div>

        <!-- Emergency result -->
        <div id="result-spoed" class="flow-step hidden">
          <div class="bg-accent-50 rounded-xl border-2 border-accent-200 p-8">
            <h2 class="text-xl font-bold text-accent-800 mb-4 text-center">Call your GP immediately</h2>
            <div class="space-y-3 mb-6">
              {practiceData.practices.map((practice) => (
                <a href={`tel:${practice.phone.replace(/\s/g, '')}`} class="flex items-center justify-between bg-white rounded-lg p-4 no-underline hover:shadow-sm transition-shadow">
                  <span class="text-sm font-medium text-neutral-900">{practice.name}</span>
                  <span class="font-semibold text-accent-700">{practice.phone}</span>
                </a>
              ))}
            </div>
            <div class="bg-accent-100 rounded-lg p-4 text-center">
              <p class="text-sm text-accent-800 font-semibold">Outside office hours (after 17:00, weekends, public holidays):</p>
              <a href={`tel:${practiceData.phoneEmergency.replace(/[\s-]/g, '')}`} class="text-2xl font-bold text-accent-700 no-underline">{practiceData.phoneEmergency}</a>
              <p class="text-xs text-accent-600 mt-1">Emergency Post Haarlem | Life-threatening emergency: call 112</p>
            </div>
            <button id="btn-back-1" class="mt-4 text-sm text-neutral-500 hover:text-neutral-700 mx-auto block">&larr; Back</button>
          </div>
        </div>

        <!-- Step 2: What would you like to do? -->
        <div id="step-2" class="flow-step hidden">
          <div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-8 text-center">
            <h2 class="text-xl font-bold text-neutral-900 mb-2">What would you like to do?</h2>
            <p class="text-sm text-neutral-500 mb-6">Choose the option that best fits your situation.</p>
            <div class="space-y-3">
              <a href={url('/en/spreekuur')} class="flex items-center gap-4 bg-neutral-50 rounded-xl p-4 no-underline hover:bg-primary-50 transition-colors group">
                <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                  </svg>
                </div>
                <div class="text-left">
                  <span class="font-semibold text-neutral-900 group-hover:text-dark-700 text-sm block">Make an appointment</span>
                  <span class="text-xs text-neutral-500">By phone or via the patient portal</span>
                </div>
              </a>
              <a href={url('/en/herhaalrecept')} class="flex items-center gap-4 bg-neutral-50 rounded-xl p-4 no-underline hover:bg-primary-50 transition-colors group">
                <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 3.75H6.912a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H15" />
                  </svg>
                </div>
                <div class="text-left">
                  <span class="font-semibold text-neutral-900 group-hover:text-dark-700 text-sm block">Request a repeat prescription</span>
                  <span class="text-xs text-neutral-500">Via the prescription line or patient portal</span>
                </div>
              </a>
              <button id="btn-bericht" class="flex items-center gap-4 bg-neutral-50 rounded-xl p-4 hover:bg-primary-50 transition-colors group w-full text-left">
                <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <span class="font-semibold text-neutral-900 group-hover:text-dark-700 text-sm block">Send a question or photo</span>
                  <span class="text-xs text-neutral-500">E.g. a skin complaint with a photo</span>
                </div>
              </button>
            </div>
            <button id="btn-back-2" class="mt-4 text-sm text-neutral-500 hover:text-neutral-700">&larr; Back</button>
          </div>
        </div>

        <!-- Step 3: Age -->
        <div id="step-3" class="flow-step hidden">
          <div class="bg-white rounded-xl border border-neutral-200 shadow-sm p-8 text-center">
            <h2 class="text-xl font-bold text-neutral-900 mb-2">Is the patient 16 years or older?</h2>
            <p class="text-sm text-neutral-500 mb-6">This determines how you can send the message.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <button
                id="btn-16plus"
                class="bg-dark-700 text-white font-semibold px-8 py-3 rounded-xl hover:bg-dark-800 transition-colors"
              >
                Yes, 16 years or older
              </button>
              <button
                id="btn-under16"
                class="bg-primary-400 text-dark-900 font-semibold px-8 py-3 rounded-xl hover:bg-primary-300 transition-colors"
              >
                No, younger than 16
              </button>
            </div>
            <button id="btn-back-3" class="mt-4 text-sm text-neutral-500 hover:text-neutral-700">&larr; Back</button>
          </div>
        </div>

        <!-- Result: 16+ -->
        <div id="result-16plus" class="flow-step hidden">
          <div class="bg-dark-50 rounded-xl border-2 border-dark-200 p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-dark-100 flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-dark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-neutral-900 mb-2">Use the patient portal</h2>
            <p class="text-sm text-neutral-600 mb-2">Send your question, photo, or e-consultation via the secure patient portal.</p>
            <p class="text-xs text-accent-600 font-medium mb-6">Do not send email to the practice -- always use the portal.</p>
            <a
              href={url('/en/patientenomgeving')}
              class="inline-flex items-center gap-2 bg-dark-700 text-white font-semibold px-8 py-3 rounded-xl no-underline hover:bg-dark-800 transition-colors"
            >
              Go to patient portal
            </a>
            <button id="btn-back-4" class="mt-4 text-sm text-neutral-500 hover:text-neutral-700 mx-auto block">&larr; Back</button>
          </div>
        </div>

        <!-- Result: <16 -->
        <div id="result-under16" class="flow-step hidden">
          <div class="bg-primary-50 rounded-xl border-2 border-primary-200 p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
              </svg>
            </div>
            <h2 class="text-xl font-bold text-neutral-900 mb-2">Send a secure message via ZIVVER</h2>
            <p class="text-sm text-neutral-600 mb-2">As a parent/guardian, you can send a secure message using a structured form.</p>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-6 text-xs text-amber-800">
              <strong>Please note:</strong> Do not use your own patient portal for your child. Your portal is linked to your own medical record.
            </div>
            <a
              href={url('/en/contact-kinderen')}
              class="inline-flex items-center gap-2 bg-primary-500 text-white font-semibold px-8 py-3 rounded-xl no-underline hover:bg-primary-600 transition-colors"
            >
              Go to secure form
            </a>
            <button id="btn-back-5" class="mt-4 text-sm text-neutral-500 hover:text-neutral-700 mx-auto block">&larr; Back</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  function showStep(id: string) {
    document.querySelectorAll('.flow-step').forEach((el) => el.classList.add('hidden'));
    document.getElementById(id)?.classList.remove('hidden');
  }

  // Step 1: Emergency?
  document.getElementById('btn-spoed-ja')?.addEventListener('click', () => showStep('result-spoed'));
  document.getElementById('btn-spoed-nee')?.addEventListener('click', () => showStep('step-2'));

  // Step 2: What would you like to do?
  document.getElementById('btn-bericht')?.addEventListener('click', () => showStep('step-3'));

  // Step 3: Age
  document.getElementById('btn-16plus')?.addEventListener('click', () => showStep('result-16plus'));
  document.getElementById('btn-under16')?.addEventListener('click', () => showStep('result-under16'));

  // Back buttons
  document.getElementById('btn-back-1')?.addEventListener('click', () => showStep('step-1'));
  document.getElementById('btn-back-2')?.addEventListener('click', () => showStep('step-1'));
  document.getElementById('btn-back-3')?.addEventListener('click', () => showStep('step-2'));
  document.getElementById('btn-back-4')?.addEventListener('click', () => showStep('step-3'));
  document.getElementById('btn-back-5')?.addEventListener('click', () => showStep('step-3'));
</script>