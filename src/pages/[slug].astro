---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  // Slugs handled by fixed .astro files or sub-routes (/gezondheid/, /medewerkers/)
  const excluded = [
    // Fixed routes (have their own .astro file)
    'home', 'contact', 'contact-kinderen', 'spreekuur', 'telefoonnummers',
    'patientenomgeving', 'klachtenformulier', 'huisbezoek', 'administratieformulier', 'spoedpost',
    'herhaalrecept', 'routebeschrijving', 'aanmelding-nieuwe-patienten',
    // /gezondheid/[slug]
    'reizigersadvisering', 'soa', 'spiraal', 'tekenbeet',
    'wrattenspreekuur', 'urineweginfecties', 'zwangerschap',
    // /medewerkers/[slug]
    'huisartsen', 'praktijkverpleegkundigen', 'praktijkassistenten',
    'huisartsen-in-opleiding',
  ];

  return pages
    .filter((p) => !excluded.includes(p.id))
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<PageLayout title={page.data.title} description={page.data.description}>
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </article>
    </div>
  </section>
</PageLayout>
