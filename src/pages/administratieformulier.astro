---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import practiceData from '../data/practices.json';
import allStaff from '../data/staff.json';

const pages = await getCollection('pages');
const page = pages.find((p) => p.id === 'administratieformulier');
const { Content } = await render(page!);

const manager = allStaff.find((s) => s.role === 'Praktijkmanager');
const managerDays = manager?.workingDays?.join(', ') || '';
const assistKey = practiceData.keuzemenu.find((item: any) => /assistent/i.test(item.label))?.key || '3';
---

<PageLayout title={page!.data.title} description={page!.data.description}>
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-neutral max-w-none prose-headings:text-neutral-900 prose-a:text-dark-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </article>

      <div class="mt-6 bg-neutral-50 rounded-xl p-6 border border-neutral-200">
        <p class="text-sm text-neutral-700">Voor administratieve verzoeken kunt u ook contact opnemen met de praktijk:</p>
        <ul class="mt-3 text-sm text-neutral-600 space-y-1.5">
          <li><strong>Telefoon:</strong> <a href={`tel:${practiceData.phoneGeneral.replace(/\s/g, '')}`} class="text-dark-600 no-underline hover:underline">{practiceData.phoneGeneral}</a> (keuze {assistKey} voor de assistente)</li>
          <li><strong>E-mail:</strong> <a href={`mailto:${practiceData.email}`} class="text-dark-600 no-underline hover:underline">{practiceData.email}</a></li>
          {manager && (
            <li><strong>Praktijkmanager:</strong> {manager.name} ({managerDays})</li>
          )}
        </ul>
      </div>
    </div>
  </section>
</PageLayout>
